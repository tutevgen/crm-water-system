<%# views/pages/installer/settings.ejs %>
<% layout('layouts/default') %>
<%
  var u = typeof profile !== 'undefined' ? profile : (typeof user !== 'undefined' ? user : {});
%>

<div class="p-4 md:p-6 max-w-2xl mx-auto space-y-6">

  <div>
    <h1 class="text-2xl font-bold text-gray-900">Настройки профиля</h1>
    <p class="text-sm text-gray-500 mt-1">Личные данные и пароль</p>
  </div>

  <!-- Аватар -->
  <div class="bg-white rounded-xl shadow-sm border p-6">
    <form action="/installer/settings/avatar" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="flex items-center gap-5">
        <div class="w-20 h-20 rounded-2xl bg-gray-100 overflow-hidden flex-shrink-0">
          <% if(u.avatar){ %>
            <img src="<%= u.avatar %>" alt="" class="w-full h-full object-cover">
          <% } else { %>
            <div class="w-full h-full flex items-center justify-center text-3xl font-bold text-gray-400">
              <%= u.name ? u.name.charAt(0).toUpperCase() : '?' %>
            </div>
          <% } %>
        </div>
        <div>
          <label class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm cursor-pointer hover:bg-gray-200 inline-block">
            Загрузить фото
            <input type="file" name="avatar" accept="image/*" class="hidden" onchange="this.form.submit()">
          </label>
          <p class="text-xs text-gray-400 mt-1">JPG, PNG до 5 МБ</p>
        </div>
      </div>
    </form>
  </div>

  <!-- Профиль -->
  <form action="/installer/settings" method="POST" class="bg-white rounded-xl shadow-sm border p-6 space-y-4" id="profileForm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="tab" value="profile">

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">ФИО</label>
      <input type="text" name="name" value="<%= u.name || '' %>" required
             class="w-full border rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
    </div>

    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Телефон</label>
        <input type="tel" name="phone" value="<%= u.phone || '' %>"
               class="w-full border rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
        <input type="email" name="email" value="<%= u.email || '' %>"
               class="w-full border rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
      </div>
    </div>

    <hr class="my-2">

    <p class="text-sm font-medium text-gray-700">Смена пароля <span class="text-gray-400 font-normal">(необязательно)</span></p>

    <div>
      <label class="block text-sm text-gray-600 mb-1">Текущий пароль</label>
      <input type="password" name="currentPassword" autocomplete="current-password"
             class="w-full border rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
    </div>
    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm text-gray-600 mb-1">Новый пароль</label>
        <input type="password" name="newPassword" minlength="6" autocomplete="new-password"
               class="w-full border rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
      </div>
      <div>
        <label class="block text-sm text-gray-600 mb-1">Повтор</label>
        <input type="password" name="confirmPassword" minlength="6" autocomplete="new-password"
               class="w-full border rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
      </div>
    </div>

    <div class="pt-2">
      <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition">
        Сохранить
      </button>
    </div>
  </form>

</div>
