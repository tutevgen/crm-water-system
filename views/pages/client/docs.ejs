  <!-- Заголовок -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Документы</h1>
      <p class="text-gray-500 mt-1">Договоры, КП, инструкции и сертификаты</p>
    </div>
  </div>

  <!-- Табы -->
  <div class="border-b border-gray-200">
    <nav class="flex gap-4 -mb-px" id="docTabs">
      <button type="button" data-tab="all" class="doc-tab px-4 py-3 text-sm font-medium border-b-2 border-blue-500 text-blue-600">
        Все документы
      </button>
      <button type="button" data-tab="contracts" class="doc-tab px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700">
        Договоры
      </button>
      <button type="button" data-tab="proposals" class="doc-tab px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700">
        КП
      </button>
      <button type="button" data-tab="instructions" class="doc-tab px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700">
        Инструкции
      </button>
      <button type="button" data-tab="certificates" class="doc-tab px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700">
        Сертификаты
      </button>
      <button type="button" data-tab="acts" class="doc-tab px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700">
        Акты
      </button>
