  var proposals = typeof proposalsList !== 'undefined' ? proposalsList : [];
  var instructions = typeof instructionsList !== 'undefined' ? instructionsList : [];
  var certificates = typeof certificatesList !== 'undefined' ? certificatesList : [];
  var acts = typeof actsList !== 'undefined' ? actsList : [];
