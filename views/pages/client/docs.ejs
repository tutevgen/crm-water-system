<script>
(function() {
  if (typeof lucide !== 'undefined') lucide.createIcons();
  
  var tabs = document.querySelectorAll('.doc-tab');
  var sections = document.querySelectorAll('.doc-section');
  var activeTab = 'all';
  
  function showTab(tab) {
    activeTab = tab;
    
    // Обновляем стили табов
    tabs.forEach(function(t) {
      if (t.dataset.tab === tab) {
        t.classList.add('border-blue-500', 'text-blue-600');
        t.classList.remove('border-transparent', 'text-gray-500');
      } else {
        t.classList.remove('border-blue-500', 'text-blue-600');
        t.classList.add('border-transparent', 'text-gray-500');
      }
    });
    
    // Показываем/скрываем секции
    sections.forEach(function(s) {
      var sectionTab = s.id.replace('tab-', '');
      if (tab === 'all' || sectionTab === tab) {
        s.classList.remove('hidden');
      } else {
        s.classList.add('hidden');
      }
    });
  }
  
  // Обработчики табов
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      showTab(this.dataset.tab);
    });
  });
  
  // Показываем все по умолчанию
  showTab('all');
})();
</script>
