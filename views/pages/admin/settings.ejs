<% layout('layouts/default') %>
<%
  var profile = typeof profile !== 'undefined' ? profile : {};
  var u = profile || {};
  var flash_success = typeof success !== 'undefined' && success.length ? success[0] : '';
  var flash_error   = typeof error   !== 'undefined' && error.length   ? error[0]   : '';
%>

<div class="p-6 max-w-4xl mx-auto space-y-6">

  <!-- Заголовок -->
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Настройки</h1>
    <p class="text-sm text-gray-500 mt-1">Управление профилем и данными аккаунта</p>
  </div>

  <!-- Уведомления -->
  <% if(flash_success){ %>
  <div class="flex items-center gap-3 px-4 py-3 bg-green-50 border border-green-200 rounded-xl text-green-800 text-sm">
    <i data-lucide="check-circle" class="w-5 h-5 text-green-600 flex-shrink-0"></i>
    <%= flash_success %>
  </div>
  <% } %>
  <% if(flash_error){ %>
  <div class="flex items-center gap-3 px-4 py-3 bg-red-50 border border-red-200 rounded-xl text-red-800 text-sm">
    <i data-lucide="alert-circle" class="w-5 h-5 text-red-600 flex-shrink-0"></i>
    <%= flash_error %>
  </div>
  <% } %>

  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">

    <!-- Левая колонка: аватар + инфо -->
    <div class="lg:col-span-1 space-y-4">

      <!-- Аватар -->
      <div class="bg-white rounded-2xl border border-gray-200 p-5 text-center">
        <form method="POST" action="/<%= u.role || 'admin' %>/settings/avatar" enctype="multipart/form-data" id="avatarForm">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="relative inline-block mb-4">
            <% if(u.avatar){ %>
              <img src="<%= u.avatar %>?t=<%= Date.now() %>" class="w-24 h-24 rounded-full object-cover border-4 border-white shadow-md mx-auto" alt="Аватар">
            <% } else { %>
              <div class="w-24 h-24 rounded-full flex items-center justify-center text-3xl font-black text-white mx-auto shadow-md"
                   style="background:linear-gradient(135deg,#111827,#374151)">
                <%= (u.name||'A').charAt(0).toUpperCase() %>
              </div>
            <% } %>
          </div>
          <div class="font-bold text-gray-900 text-lg"><%= u.name||'Администратор' %></div>
          <div class="text-xs text-gray-400 mt-1 capitalize"><%= u.role||'admin' %></div>
          <div class="text-xs text-gray-500 mt-1"><%= u.email||'' %></div>
          <div class="mt-4">
            <label class="cursor-pointer inline-flex items-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 rounded-xl text-sm font-medium hover:bg-gray-200 transition">
              <i data-lucide="camera" class="w-4 h-4"></i> Загрузить фото
              <input type="file" name="avatar" accept="image/jpeg,image/png,image/webp,image/gif" class="hidden"
                     onchange="if(this.files.length) document.getElementById('avatarForm').submit();">
            </label>
            <p class="text-[11px] text-gray-400 mt-1">JPG, PNG до 2 МБ</p>
          </div>
        </form>
      </div>

      <!-- Статус аккаунта -->
      <div class="bg-white rounded-2xl border border-gray-200 p-5 space-y-3">
        <div class="text-xs font-bold uppercase tracking-wide text-gray-400">Аккаунт</div>
        <div class="flex items-center justify-between text-sm">
          <span class="text-gray-500">Статус</span>
          <span class="px-2 py-0.5 bg-green-100 text-green-700 rounded-full text-xs font-semibold">Активен</span>
        </div>
        <div class="flex items-center justify-between text-sm">
          <span class="text-gray-500">Роль</span>
          <span class="font-semibold text-gray-800">Администратор</span>
        </div>
        <% if(u.createdAt){ %>
        <div class="flex items-center justify-between text-sm">
          <span class="text-gray-500">В системе с</span>
          <span class="font-semibold text-gray-800"><%= new Date(u.createdAt).toLocaleDateString('ru-RU') %></span>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Правая колонка: формы -->
    <div class="lg:col-span-3 space-y-5">

      <!-- ── Личные данные ── -->
      <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:#111827">
            <i data-lucide="user" class="w-4 h-4 text-white"></i>
          </div>
          <div>
            <div class="font-bold text-gray-900">Личные данные</div>
            <div class="text-xs text-gray-400">Имя, телефон, email</div>
          </div>
        </div>
        <form method="POST" action="/admin/settings" class="p-6 space-y-4">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="tab" value="profile">

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Имя *</label>
              <input type="text" name="name" value="<%= u.name||'' %>" required
                placeholder="Евгений Морозов"
                class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent transition">
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Телефон</label>
              <input type="tel" name="phone" value="<%= u.phone||'' %>"
                placeholder="8 966-199-97-63"
                class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent transition">
            </div>
            <div class="sm:col-span-2">
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Email *</label>
              <input type="email" name="email" value="<%= u.email||'' %>" required
                placeholder="admin@nova-filter.ru"
                class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent transition">
            </div>
          </div>

          <div class="flex justify-end pt-2">
            <button type="submit"
              class="px-5 py-2.5 text-sm font-semibold text-white rounded-xl transition flex items-center gap-2"
              style="background:#111827"
              onmouseover="this.style.background='#1f2937'" onmouseout="this.style.background='#111827'">
              <i data-lucide="save" class="w-4 h-4"></i> Сохранить
            </button>
          </div>
        </form>
      </div>

      <!-- ── Смена пароля ── -->
      <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:#374151">
            <i data-lucide="lock" class="w-4 h-4 text-white"></i>
          </div>
          <div>
            <div class="font-bold text-gray-900">Смена пароля</div>
            <div class="text-xs text-gray-400">Минимум 6 символов</div>
          </div>
        </div>
        <form method="POST" action="/admin/settings" class="p-6 space-y-4">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="tab" value="profile">

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Текущий пароль</label>
              <input type="password" name="currentPassword" placeholder="••••••••"
                class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent transition">
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Новый пароль</label>
              <input type="password" name="newPassword" id="newPass" placeholder="••••••••"
                class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent transition">
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5">Подтверждение</label>
              <input type="password" name="confirmPassword" id="confirmPass" placeholder="••••••••"
                class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent transition"
                oninput="checkPassMatch()">
            </div>
          </div>

          <div id="passMatchMsg" class="text-xs text-red-500 hidden">Пароли не совпадают</div>

          <div class="flex justify-end pt-2">
            <button type="submit" id="passSubmitBtn"
              class="px-5 py-2.5 text-sm font-semibold text-white rounded-xl transition flex items-center gap-2"
              style="background:#111827">
              <i data-lucide="key" class="w-4 h-4"></i> Изменить пароль
            </button>
          </div>
        </form>
      </div>

      <!-- ── Информация о системе ── -->
      <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-gray-100">
            <i data-lucide="info" class="w-4 h-4 text-gray-600"></i>
          </div>
          <div>
            <div class="font-bold text-gray-900">Информация о системе</div>
          </div>
        </div>
        <div class="p-6 grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
          <% [
            ['Версия CRM', 'Nova Filter CRM v1.0'],
            ['База данных', 'MongoDB Atlas'],
            ['Окружение', process.env.NODE_ENV||'development'],
            ['Часовой пояс', 'Europe/Moscow']
          ].forEach(function(r){ %>
          <div class="flex justify-between py-2 border-b border-gray-100 last:border-0">
            <span class="text-gray-400"><%= r[0] %></span>
            <span class="font-semibold text-gray-700"><%= r[1] %></span>
          </div>
          <% }); %>
        </div>
      </div>

    </div><!-- /right col -->
  </div><!-- /grid -->
</div>

<script>
function checkPassMatch() {
  var np = document.getElementById('newPass').value;
  var cp = document.getElementById('confirmPass').value;
  var msg = document.getElementById('passMatchMsg');
  var btn = document.getElementById('passSubmitBtn');
  if (cp && np !== cp) {
    msg.classList.remove('hidden');
    btn.disabled = true;
    btn.style.opacity = '0.5';
  } else {
    msg.classList.add('hidden');
    btn.disabled = false;
    btn.style.opacity = '1';
  }
}
</script>
