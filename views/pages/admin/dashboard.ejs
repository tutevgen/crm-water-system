<%# views/pages/admin/dashboard.ejs %>
<% layout('layouts/default') %>
<%
  var s  = typeof stats !== 'undefined' ? stats : {};
  var fmt = function(n){ return (Number(n)||0).toLocaleString('ru-RU'); };
  var recent = s.recentProposals || [];
  var miniCal = typeof miniCalDays !== 'undefined' ? miniCalDays : [];
  var unavail = typeof unavailableStaff !== 'undefined' ? unavailableStaff : [];
  var recentReqs = typeof recentRequests !== 'undefined' ? recentRequests : [];
  var fmtDate = function(d){ return d ? new Date(d).toLocaleDateString('ru-RU') : '—'; };
  var statusNames = {
    draft:'Черновик', sent:'Отправлено', viewed:'Просмотрено',
    accepted:'Принято', accepted_premium:'Принято (премиум)',
    in_progress:'В работе', installed:'Смонтировано',
    rejected:'Отклонено', expired:'Истекло'
  };
  var statusColors = {
    draft:'bg-gray-100 text-gray-600', sent:'bg-blue-100 text-blue-700',
    viewed:'bg-purple-100 text-purple-700', accepted:'bg-green-100 text-green-700',
    accepted_premium:'bg-amber-100 text-amber-800', in_progress:'bg-indigo-100 text-indigo-700',
    installed:'bg-emerald-100 text-emerald-700', rejected:'bg-red-100 text-red-700'
  };
  var availNames = { vacation:'В отпуске', sick:'Болеет', busy:'Занят', day_off:'Выходной' };
  var availColors = { vacation:'bg-orange-100 text-orange-700', sick:'bg-red-100 text-red-700', busy:'bg-yellow-100 text-yellow-700', day_off:'bg-gray-100 text-gray-600' };
  var typeNames = { maintenance:'ТО', refill:'Перезасыпка', repair:'Ремонт', analysis:'Анализ', other:'Заявка' };
%>

<div class="p-5 md:p-7 max-w-7xl mx-auto space-y-6">

  <!-- Заголовок -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-black text-gray-900">Панель управления</h1>
      <p class="text-sm text-gray-400 mt-0.5"><%= new Date().toLocaleDateString('ru-RU',{weekday:'long',day:'numeric',month:'long',year:'numeric'}) %></p>
    </div>
    <a href="/admin/proposals/create" class="px-4 py-2.5 text-sm font-semibold text-white rounded-xl flex items-center gap-2 shadow-sm" style="background:#111827">
      <i data-lucide="plus" class="w-4 h-4"></i> Новое КП
    </a>
  </div>

  <!-- Карточки оборота -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="col-span-2 rounded-2xl p-5 text-white" style="background:linear-gradient(135deg,#111827,#374151)">
      <div class="flex items-center justify-between mb-3">
        <div class="text-xs font-bold uppercase tracking-widest opacity-60">Оборот за месяц</div>
        <div class="w-9 h-9 rounded-xl bg-white/10 flex items-center justify-center"><i data-lucide="trending-up" class="w-5 h-5"></i></div>
      </div>
      <div class="text-3xl font-black leading-none mb-1"><%= fmt(s.revenueMonth) %> ₽</div>
      <div class="text-xs opacity-50">Смонтировано: <%= s.installedMonth||0 %> систем</div>
    </div>
    <div class="rounded-2xl p-5 bg-white border">
      <div class="flex items-center justify-between mb-3">
        <div class="text-xs font-bold uppercase tracking-widest text-gray-400">Общий оборот</div>
        <div class="w-9 h-9 rounded-xl bg-gray-100 flex items-center justify-center"><i data-lucide="bar-chart-2" class="w-5 h-5 text-gray-600"></i></div>
      </div>
      <div class="text-2xl font-black text-gray-900 leading-none mb-1"><%= fmt(s.revenueTotal) %> ₽</div>
      <div class="text-xs text-gray-400">Всего: <%= s.installed||0 %></div>
    </div>
    <div class="rounded-2xl p-5 bg-white border">
      <div class="flex items-center justify-between mb-3">
        <div class="text-xs font-bold uppercase tracking-widest text-gray-400">КП за месяц</div>
        <div class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center"><i data-lucide="file-check" class="w-5 h-5 text-blue-600"></i></div>
      </div>
      <div class="text-2xl font-black text-gray-900 leading-none mb-1"><%= s.proposalsMonth||0 %></div>
      <div class="text-xs text-gray-400">Всего КП: <%= s.proposals||0 %></div>
    </div>
  </div>

  <!-- Метрики -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <% [{icon:'users',bg:'bg-blue-50',ic:'text-blue-600',val:s.clients||0,lbl:'Клиентов'},
        {icon:'send',bg:'bg-amber-50',ic:'text-amber-600',val:s.pending||0,lbl:'Ждут ответа'},
        {icon:'wrench',bg:'bg-indigo-50',ic:'text-indigo-600',val:s.inWork||0,lbl:'В работе'},
        {icon:'package',bg:'bg-gray-100',ic:'text-gray-600',val:s.products||0,lbl:'Товаров'}
    ].forEach(function(c){ %>
    <div class="bg-white rounded-2xl border p-4 flex items-center gap-4">
      <div class="w-11 h-11 rounded-xl <%= c.bg %> flex items-center justify-center flex-shrink-0"><i data-lucide="<%= c.icon %>" class="w-5 h-5 <%= c.ic %>"></i></div>
      <div><div class="text-2xl font-black text-gray-900 leading-none"><%= c.val %></div><div class="text-xs text-gray-400 mt-0.5"><%= c.lbl %></div></div>
    </div>
    <% }); %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

    <!-- Мини-календарь на 7 дней -->
    <div class="lg:col-span-2 bg-white rounded-2xl border overflow-hidden">
      <div class="px-5 py-4 border-b flex items-center justify-between">
        <h2 class="font-bold text-gray-900 flex items-center gap-2"><i data-lucide="calendar-days" class="w-4 h-4 text-gray-500"></i> Ближайшие 7 дней</h2>
        <a href="/admin/calendar" class="text-xs font-semibold text-blue-600 hover:text-blue-800">Полный календарь →</a>
      </div>
      <div class="grid grid-cols-7 divide-x">
        <% miniCal.forEach(function(day){ %>
        <div class="p-2 min-h-[120px] <%= day.isToday ? 'bg-blue-50' : day.isYesterday ? 'bg-gray-50' : '' %>">
          <div class="text-center mb-2">
            <div class="text-[10px] uppercase text-gray-400 font-medium"><%= day.dayOfWeek %></div>
            <div class="text-lg font-bold <%= day.isToday ? 'text-blue-600' : 'text-gray-700' %>"><%= day.dayNum %></div>
          </div>
          <div class="space-y-1">
            <% day.events.slice(0,3).forEach(function(ev){ %>
            <a href="<%= ev.url %>" class="block px-1.5 py-0.5 rounded text-[10px] leading-tight truncate hover:opacity-80
              <%= ev.type === 'installation' ? 'bg-indigo-100 text-indigo-700' : ev.type === 'reminder' ? 'bg-violet-100 text-violet-700' : 'bg-orange-100 text-orange-700' %>"
               title="<%= ev.title %>">
              <%= ev.title.substring(0,15) %><%= ev.title.length > 15 ? '…' : '' %>
            </a>
            <% }) %>
            <% if(day.events.length > 3){ %><div class="text-[10px] text-gray-400 text-center">+<%= day.events.length - 3 %></div><% } %>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- Правая колонка: недоступные + заявки -->
    <div class="space-y-4">

      <!-- Кто недоступен -->
      <% if(unavail.length > 0){ %>
      <div class="bg-white rounded-2xl border p-5">
        <h2 class="font-bold text-gray-900 mb-3 flex items-center gap-2"><i data-lucide="user-x" class="w-4 h-4 text-red-400"></i> Недоступны сейчас</h2>
        <div class="space-y-2">
          <% unavail.forEach(function(u){ %>
          <div class="flex items-center gap-3 p-2 rounded-lg bg-gray-50">
            <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center flex-shrink-0 overflow-hidden">
              <% if(u.avatar){ %><img src="<%= u.avatar %>" class="w-full h-full object-cover"><% } else { %><span class="text-xs font-bold text-gray-500"><%= u.name ? u.name.charAt(0) : '?' %></span><% } %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate"><%= u.name %></p>
              <span class="text-xs px-1.5 py-0.5 rounded-full font-medium <%= availColors[u.availability] || 'bg-gray-100' %>"><%= availNames[u.availability] || u.availability %></span>
            </div>
            <% if(u.availabilityUntil){ %><span class="text-[10px] text-gray-400">до <%= fmtDate(u.availabilityUntil) %></span><% } %>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- Новые заявки -->
      <div class="bg-white rounded-2xl border p-5">
        <h2 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
          <i data-lucide="inbox" class="w-4 h-4 text-orange-500"></i> Новые заявки
          <% if(recentReqs.length){ %><span class="ml-auto text-xs bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full"><%= recentReqs.length %></span><% } %>
        </h2>
        <% if(recentReqs.length === 0){ %>
          <p class="text-sm text-gray-400">Новых заявок нет</p>
        <% } else { %>
        <div class="space-y-2">
          <% recentReqs.forEach(function(r){ %>
          <a href="/admin/requests" class="flex items-center gap-3 p-2 rounded-lg hover:bg-gray-50 group">
            <div class="w-8 h-8 rounded-lg bg-orange-50 flex items-center justify-center flex-shrink-0"><i data-lucide="wrench" class="w-4 h-4 text-orange-600"></i></div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate"><%= typeNames[r.serviceType] || r.serviceType %> — <%= r.clientName || (r.clientId && r.clientId.name) || '' %></p>
              <p class="text-xs text-gray-400"><%= fmtDate(r.createdAt) %></p>
            </div>
            <i data-lucide="chevron-right" class="w-4 h-4 text-gray-300 group-hover:text-gray-500"></i>
          </a>
          <% }) %>
        </div>
        <a href="/admin/requests" class="block text-center text-xs text-blue-600 mt-3 hover:underline">Все заявки →</a>
        <% } %>
      </div>

      <!-- Быстрые действия -->
      <div class="bg-white rounded-2xl border p-5">
        <h2 class="font-bold text-gray-900 mb-3 flex items-center gap-2"><i data-lucide="zap" class="w-4 h-4 text-gray-500"></i> Быстрые действия</h2>
        <div class="space-y-2">
          <% [{href:'/admin/proposals/create',icon:'file-plus',label:'Создать КП'},
              {href:'/admin/clients',icon:'user-plus',label:'Клиенты'},
              {href:'/admin/orders',icon:'clipboard-list',label:'Заказы'},
              {href:'/admin/products',icon:'package',label:'Каталог'}
          ].forEach(function(a){ %>
          <a href="<%= a.href %>" class="flex items-center gap-3 p-2.5 rounded-xl hover:bg-gray-50 border border-gray-100 group">
            <div class="w-8 h-8 rounded-lg bg-gray-100 group-hover:bg-gray-200 flex items-center justify-center flex-shrink-0"><i data-lucide="<%= a.icon %>" class="w-4 h-4 text-gray-600"></i></div>
            <span class="text-sm font-semibold text-gray-800"><%= a.label %></span>
            <i data-lucide="chevron-right" class="w-4 h-4 text-gray-300 ml-auto"></i>
          </a>
          <% }); %>
        </div>
      </div>
    </div>
  </div>

  <!-- Последние КП -->
  <div class="bg-white rounded-2xl border overflow-hidden">
    <div class="px-5 py-4 border-b flex items-center justify-between">
      <h2 class="font-bold text-gray-900 flex items-center gap-2"><i data-lucide="file-check" class="w-4 h-4 text-gray-500"></i> Последние КП</h2>
      <a href="/admin/proposals" class="text-xs font-semibold text-blue-600">Все КП →</a>
    </div>
    <% if(recent.length === 0){ %>
    <div class="p-8 text-center"><p class="text-sm text-gray-400">КП ещё нет</p></div>
    <% } else { %>
    <table class="w-full text-sm">
      <thead><tr class="bg-gray-50"><th class="px-4 py-3 text-left text-xs font-bold text-gray-400">Номер</th><th class="px-4 py-3 text-left text-xs font-bold text-gray-400">Клиент</th><th class="px-4 py-3 text-right text-xs font-bold text-gray-400">Сумма</th><th class="px-4 py-3 text-center text-xs font-bold text-gray-400">Статус</th></tr></thead>
      <tbody class="divide-y">
        <% recent.forEach(function(p){ %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3"><a href="/admin/proposals/<%= p._id %>" class="font-semibold text-blue-600 hover:underline text-xs"><%= p.proposalNumber %></a></td>
          <td class="px-4 py-3 font-medium text-gray-800 max-w-[140px] truncate"><%= p.clientName||'—' %></td>
          <td class="px-4 py-3 text-right font-bold text-gray-900 text-xs"><%= fmt(p.acceptedAmount||p.totalPrice||0) %> ₽</td>
          <td class="px-4 py-3 text-center"><span class="px-2 py-0.5 rounded-full text-xs font-semibold <%= statusColors[p.status]||'bg-gray-100' %>"><%= statusNames[p.status]||p.status %></span></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>
