<% layout('layouts/default') %>
<%
  var p       = proposal || {};
  var company = companyInfo || {};
  var items   = p.items || [];
  var opts    = p.recommendedOptions || [];
  var svc     = p.services || {};
  var incs    = p.includes || [];
  var anal    = p.waterAnalysis || {};
  var fmt     = function(n){ return (Number(n)||0).toLocaleString('ru-RU'); };
  var daysLeft = 0;
  if (p.validUntil) daysLeft = Math.max(0,Math.ceil((new Date(p.validUntil)-new Date())/(864e5)));

  var waterParams = [
    {k:'iron',            lbl:'Железо (Fe)',       u:'мг/л',   norm:0.3},
    {k:'manganese',       lbl:'Марганец (Mn)',      u:'мг/л',   norm:0.1},
    {k:'hardness',        lbl:'Жёсткость',          u:'°Ж',     norm:7},
    {k:'ph',              lbl:'pH',                u:'',       normMin:6,normMax:9},
    {k:'hydrogen_sulfide',lbl:'Сероводород (H₂S)', u:'мг/л',   norm:0.03},
    {k:'oxidability',     lbl:'Окисляемость',       u:'мгО₂/л', norm:5},
    {k:'turbidity',       lbl:'Мутность',           u:'ЕМФ',    norm:2.6},
    {k:'tds',             lbl:'TDS (минерализация)',u:'мг/л',   norm:1000}
  ];
  var hasAnal = waterParams.some(function(k){ return anal[k.k]; });

  var statusLabel = {
    draft:'Черновик', sent:'Отправлено', viewed:'Просмотрено',
    accepted:'Принято (стандарт)', accepted_premium:'Принято (премиум)',
    in_progress:'В работе', installed:'Смонтировано',
    rejected:'Отклонено', expired:'Истекло'
  }[p.status||'draft']||'';
  var statusColor = {
    draft:'bg-gray-100 text-gray-600',
    sent:'bg-blue-100 text-blue-700',
    viewed:'bg-purple-100 text-purple-700',
    accepted:'bg-green-100 text-green-700',
    accepted_premium:'bg-amber-100 text-amber-800',
    in_progress:'bg-indigo-100 text-indigo-700',
    installed:'bg-emerald-100 text-emerald-700',
    rejected:'bg-red-100 text-red-700',
    expired:'bg-yellow-100 text-yellow-700'
  }[p.status||'draft']||'bg-gray-100 text-gray-600';

  var results = {
    iron:            {was:'Желтый налёт, запах железа',    gets:'Чистая прозрачная вода без запаха'},
    manganese:       {was:'Осадок, пятна на посуде',       gets:'Чистые трубы и бельё'},
    hardness:        {was:'Накипь, поломки техники',       gets:'Нет накипи, техника служит дольше'},
    ph:              {was:'Агрессивная вода',              gets:'Нейтральный pH, безопасно'},
    hydrogen_sulfide:{was:'Запах тухлых яиц',              gets:'Вода без запаха'},
    oxidability:     {was:'Органика, неприятный привкус',  gets:'Чистый вкус воды'},
    turbidity:       {was:'Мутная вода, взвесь',           gets:'Прозрачная вода'},
    tds:             {was:'Солёный привкус, минерализация', gets:'Нормальное солесодержание'}
  };
  var problems = waterParams.filter(function(wp){
    if(!anal[wp.k]) return false;
    var v=parseFloat(anal[wp.k]);
    if(wp.normMin!=null) return v<wp.normMin||v>wp.normMax;
    return v>wp.norm;
  });

  var optIcons = {uv_sterilizer:'☀️',leak_protection:'🛡',ro_system:'💧',thermal_cover:'🧥',bypass:'🔀'};

  function groupByCat(arr){
    var g={},o=[];
    (arr||[]).forEach(function(item){
      var c=item.category||'';
      if(!g[c]){g[c]=[];o.push(c);}
      g[c].push(item);
    });
    return {groups:g,order:o};
  }
  var mainEq  = groupByCat(items);
  var premItems = p.premiumItems||[];
  var premEq  = groupByCat(premItems);
  var hasSvc  = svc.delivery||svc.installation||svc.commissioning||svc.chiefInstallation||svc.materials;
  var svcList = [
    {k:'delivery',         lbl:'Доставка',            pk:'deliveryPrice'},
    {k:'installation',     lbl:'Монтаж',              pk:'installationPrice'},
    {k:'chiefInstallation',lbl:'Шеф-монтаж',          pk:'chiefInstallationPrice'},
    {k:'commissioning',    lbl:'Пуско-наладка',       pk:'commissioningPrice'},
    {k:'materials',        lbl:'Расходные материалы', pk:'materialsPrice'}
  ];
  var eqCounter = 0;
%>

<style>
@media print { .no-print{display:none!important} @page{margin:15mm} }
.sec-title{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:#6b7280;border-bottom:2px solid #111827;padding-bottom:5px;margin-bottom:12px}
.val-ok{color:#16a34a;font-weight:700}
.val-bad{color:#dc2626;font-weight:700;background:#fff5f5;border-radius:3px;padding:1px 4px}
.badge-ok{display:inline-block;background:#dcfce7;color:#166534;border-radius:4px;padding:2px 8px;font-size:11px;font-weight:700}
.badge-bad{display:inline-block;background:#fee2e2;color:#991b1b;border-radius:4px;padding:2px 8px;font-size:11px;font-weight:700}
.eq-num{width:28px;height:28px;border-radius:50%;background:#111827;color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;flex-shrink:0}
.prem-num{width:26px;height:26px;border-radius:50%;background:#374151;color:#fff;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;flex-shrink:0}
</style>

<div class="p-4 md:p-6 max-w-4xl mx-auto space-y-5">

  <!-- ── ШАПКА ── -->
  <div class="rounded-2xl overflow-hidden" style="background:linear-gradient(135deg,#111827 0%,#1f2937 60%,#374151 100%)">
    <div class="p-6 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
      <div>
        <img src="/img/logo.png" alt="Логотип" class="h-10 mb-4" style="filter:brightness(0) invert(1)" onerror="this.style.display='none'">
        <div class="text-xs uppercase tracking-widest mb-1" style="color:#9ca3af">Коммерческое предложение</div>
        <div class="text-3xl font-black leading-none mb-2 text-white"><%= p.proposalNumber||'—' %></div>
        <div class="text-base" style="color:#d1d5db">для <span class="font-bold text-white"><%= p.clientName||'Клиента' %></span></div>
      </div>
      <div class="flex flex-col gap-2 sm:items-end text-sm">
        <span class="px-3 py-1.5 rounded-full text-xs font-semibold <%= statusColor %> no-print"><%= statusLabel %></span>
        <div style="color:#9ca3af" class="text-xs">Создано: <span class="font-semibold" style="color:#e5e7eb"><%= p.createdAt?new Date(p.createdAt).toLocaleDateString('ru-RU'):'—' %></span></div>
        <% if(p.validUntil){ %>
        <% var validStyle = daysLeft<=3 ? 'color:#fcd34d;font-weight:700' : 'color:#9ca3af'; %>
        <div class="text-xs" style="<%= validStyle %>">До: <span style="color:#e5e7eb"><%= new Date(p.validUntil).toLocaleDateString('ru-RU') %></span></div>
        <% } %>
        <% if(company.phone){ %><div class="font-bold text-white text-base mt-1">📞 <%= company.phone %></div><% } %>
        <% if(company.email){ %><div class="text-xs" style="color:#9ca3af">✉ <%= company.email %></div><% } %>
      </div>
    </div>
  </div>

  <!-- Срочность -->
  <% if(daysLeft>0&&daysLeft<=5&&['sent','viewed'].includes(p.status)){ %>
  <div class="bg-amber-50 border border-amber-300 rounded-xl p-4 flex items-center gap-3 no-print">
    <i data-lucide="clock" class="w-5 h-5 text-amber-600 flex-shrink-0"></i>
    <div class="text-amber-800 font-medium text-sm">Предложение действительно ещё <strong><%= daysLeft %></strong> <%= daysLeft===1?'день':daysLeft<5?'дня':'дней' %></div>
  </div>
  <% } %>

  <!-- ── ОБЪЕКТ ── -->
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="sec-title">Информация об объекте</div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
      <% if(p.objectAddress){ %><div class="col-span-2 md:col-span-4 pb-3 border-b border-gray-100"><div class="text-xs text-gray-400 font-semibold uppercase tracking-wide mb-1">Адрес</div><div class="font-semibold"><%= p.objectAddress %></div></div><% } %>
      <div><div class="text-xs text-gray-400 font-semibold uppercase tracking-wide mb-1">Тип</div><div class="font-semibold"><%= {house:'Частный дом',dacha:'Дача',apartment:'Квартира',commercial:'Коммерческое',production:'Производство'}[p.objectType]||'—' %></div></div>
      <div><div class="text-xs text-gray-400 font-semibold uppercase tracking-wide mb-1">Источник</div><div class="font-semibold"><%= {borehole:'Скважина',well:'Колодец',central:'Центральное',river:'Река/озеро'}[p.waterSource]||'—' %></div></div>
      <div><div class="text-xs text-gray-400 font-semibold uppercase tracking-wide mb-1">Жильцов</div><div class="font-semibold"><%= p.residents||4 %> чел.</div></div>
      <div><div class="text-xs text-gray-400 font-semibold uppercase tracking-wide mb-1">Точек водоразбора</div><div class="font-semibold"><%= p.waterPoints||8 %> шт.</div></div>
    </div>
  </div>

  <!-- ── АНАЛИЗ ВОДЫ ── -->
  <% if(hasAnal){ %>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="sec-title">Анализ воды</div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr style="background:#111827">
            <th class="text-left py-2.5 px-3 text-xs font-bold uppercase tracking-wide text-white rounded-tl-lg">Показатель</th>
            <th class="text-right py-2.5 px-3 text-xs font-bold uppercase tracking-wide text-white">Значение</th>
            <th class="text-right py-2.5 px-3 text-xs font-bold uppercase tracking-wide text-white">Норма</th>
            <th class="text-center py-2.5 px-3 text-xs font-bold uppercase tracking-wide text-white rounded-tr-lg">Статус</th>
          </tr>
        </thead>
        <tbody>
        <% waterParams.forEach(function(wp,wi){ if(!anal[wp.k]) return;
          var val=parseFloat(anal[wp.k]);
          var ok=wp.normMin!=null?(val>=wp.normMin&&val<=wp.normMax):(val<=wp.norm);
        %>
          <% var rowBg = wi%2===0 ? 'bg-white' : 'bg-gray-50'; %>
          <tr class="border-b border-gray-100 <%= rowBg %>">
          <td class="py-2.5 px-3 font-semibold"><%= wp.lbl %></td>
          <% var valCls = ok ? 'val-ok' : 'val-bad'; %>
          <td class="py-2.5 px-3 text-right"><span class="<%= valCls %>"><%= val %> <%= wp.u %></span></td>
          <td class="py-2.5 px-3 text-right text-gray-400 text-xs"><% if(wp.normMin!=null){ %><%= wp.normMin %>–<%= wp.normMax %><% }else{ %>≤ <%= wp.norm %><% } %> <%= wp.u %></td>
          <% var badgeCls = ok ? 'badge-ok' : 'badge-bad'; var badgeTxt = ok ? 'НОРМА' : 'ПРЕВЫШЕНИЕ'; %>
          <td class="py-2.5 px-3 text-center"><span class="<%= badgeCls %>"><%= badgeTxt %></span></td>
        </tr>
        <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>

  <!-- ── ЧТО ИЗМЕНИТСЯ ── -->
  <% if(problems.length>0){ %>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="sec-title">Результат после установки системы</div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <% problems.forEach(function(wp){ var r=results[wp.k]; if(!r) return; %>
      <div class="border border-gray-100 rounded-lg p-3 bg-gray-50">
        <div class="text-xs font-bold uppercase tracking-wide text-gray-500 mb-2"><%= wp.lbl %></div>
        <div class="text-xs text-red-600 mb-1">— Сейчас: <%= r.was %></div>
        <div class="text-xs text-green-700">+ После: <%= r.gets %></div>
      </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- ── СХЕМА ── -->
  <% if(p.schemaImage){ %>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="sec-title">Технологическая схема очистки</div>
    <img src="<%= p.schemaImage %>" alt="Схема" class="rounded-lg border border-gray-100 max-w-full mx-auto block" style="max-height:400px;object-fit:contain">
  </div>
  <% } %>

  <!-- ── ОБОРУДОВАНИЕ (карточный стиль) ── -->
  <% if(items.length>0){ %>
  <div class="rounded-xl overflow-hidden border border-gray-200">
    <div class="flex items-center justify-between px-5 py-3" style="background:#111827">
      <h2 class="font-bold text-white flex items-center gap-2 text-sm">
        <i data-lucide="package" class="w-4 h-4 text-gray-400"></i> Состав оборудования
      </h2>
      <span class="text-xs text-gray-400"><%= items.length %> позиций</span>
    </div>
    <div class="divide-y divide-gray-100 bg-white">
      <% mainEq.order.forEach(function(cat){ var catItems=mainEq.groups[cat]; %>
      <% if(cat && mainEq.order.length>1){ %>
      <div class="px-5 py-2 text-xs font-black uppercase tracking-widest text-gray-400" style="background:#f9fafb"><%= cat %></div>
      <% } %>
      <% catItems.forEach(function(item){ eqCounter++; %>
      <div class="flex items-center gap-4 px-5 py-3.5 hover:bg-gray-50 transition-colors">
        <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-black text-white flex-shrink-0" style="background:#111827"><%= eqCounter %></div>
        <div class="w-10 h-10 rounded-lg border border-gray-100 bg-gray-50 flex items-center justify-center flex-shrink-0 overflow-hidden">
          <% if(item.image){ %><img src="<%= item.image %>" class="w-full h-full object-contain"><% }else{ %><span class="text-gray-300 text-lg">📦</span><% } %>
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-semibold text-gray-900 text-sm"><%= item.name %></div>
          <% if(item.description){ %><div class="text-xs text-gray-400 mt-0.5">→ <%= item.description %></div><% } %>
          <% if(item.sku){ %><div class="text-xs text-gray-300 mt-0.5">Арт.: <%= item.sku %></div><% } %>
        </div>
        <div class="text-sm text-gray-400 flex-shrink-0 w-16 text-right"><%= item.quantity||1 %> <%= item.unit||'шт' %></div>
        <div class="text-sm text-gray-400 flex-shrink-0 w-24 text-right"><%= fmt(item.price) %> ₽</div>
        <div class="text-sm font-bold text-gray-900 flex-shrink-0 w-24 text-right"><%= fmt((item.quantity||1)*item.price) %> ₽</div>
      </div>
      <% }); }); %>
    </div>
    <% if(p.pipingMaterialName){ %>
    <div class="flex justify-between items-center px-5 py-3 text-sm border-t border-gray-100" style="background:#f9fafb">
      <span class="text-gray-500">Обвязка: <span class="font-semibold text-gray-700"><%= p.pipingMaterialName %></span></span>
      <span class="font-bold text-gray-900"><%= fmt(p.pipingMaterialPrice) %> ₽</span>
    </div>
    <% } %>
  </div>
  <% } %>


  <!-- ── УСЛУГИ ── -->
  <% if(hasSvc){ %>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="sec-title">Услуги</div>
    <div class="space-y-2">
      <% svcList.forEach(function(sv){ if(!svc[sv.k]) return; %>
      <div class="flex justify-between py-2 border-b border-gray-100 last:border-0 text-sm">
        <span class="text-gray-600"><%= sv.lbl %></span>
        <span class="font-bold"><%= fmt(svc[sv.pk]||0) %> ₽</span>
      </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- ── ИТОГО ОСНОВНОЕ ── -->
  <div class="rounded-xl overflow-hidden" style="background:#111827">
    <div class="p-5 space-y-2">
      <% if(p.equipmentTotal>0){ %><div class="flex justify-between text-sm" style="color:#9ca3af"><span>Оборудование</span><span><%= fmt(p.equipmentTotal) %> ₽</span></div><% } %>
      <% if(p.pipingMaterialPrice>0){ %><div class="flex justify-between text-sm" style="color:#9ca3af"><span>Обвязка (<%= p.pipingMaterialName||'' %>)</span><span><%= fmt(p.pipingMaterialPrice) %> ₽</span></div><% } %>
      <% if(p.servicesTotal>0){ %><div class="flex justify-between text-sm" style="color:#9ca3af"><span>Услуги</span><span><%= fmt(p.servicesTotal) %> ₽</span></div><% } %>
      <% if(p.clientDiscount>0){ %><div class="flex justify-between text-sm" style="color:#6ee7b7"><span>Скидка клиента (<%= p.clientDiscount %>%)</span><span>−<%= fmt(p.clientDiscountAmount) %> ₽</span></div><% } %>
      <% if(p.discount>0){ %><div class="flex justify-between text-sm" style="color:#6ee7b7"><span>Скидка менеджера (<%= p.discount %>%)</span><span>−<%= fmt(p.discountAmount) %> ₽</span></div><% } %>
    </div>
    <div class="flex justify-between items-center px-5 py-4 border-t" style="border-color:#374151">
      <span class="text-sm font-bold uppercase tracking-widest" style="color:#d1d5db">Итого к оплате</span>
      <span class="text-3xl font-black text-white"><%= fmt(p.totalPrice||0) %> ₽</span>
    </div>
  </div>

  <!-- ── ПРЕМИУМ ВАРИАНТ (синий стиль) ── -->
  <% if(premItems.length>0){ %>
  <% var premCounter=0; %>
  <div class="rounded-xl overflow-hidden border border-blue-200">
    <div class="flex items-center justify-between px-5 py-3" style="background:#1e40af">
      <h2 class="font-bold text-white flex items-center gap-2 text-sm">
        <i data-lucide="crown" class="w-4 h-4 text-blue-300"></i> Премиум вариант
        <span class="text-xs font-normal text-blue-300 ml-1">Расширенная комплектация</span>
      </h2>
      <span class="text-xs text-blue-300"><%= premItems.length %> позиций</span>
    </div>
    <div class="divide-y divide-blue-50 bg-white">
      <% premEq.order.forEach(function(cat){ var catItems=premEq.groups[cat]; %>
      <% if(cat && premEq.order.length>1){ %>
      <div class="px-5 py-2 text-xs font-black uppercase tracking-widest text-blue-400" style="background:#eff6ff"><%= cat %></div>
      <% } %>
      <% catItems.forEach(function(item){ premCounter++; %>
      <div class="flex items-center gap-4 px-5 py-3.5 hover:bg-blue-50/50 transition-colors">
        <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-black text-white flex-shrink-0" style="background:#1e40af"><%= premCounter %></div>
        <div class="w-10 h-10 rounded-lg border border-blue-100 bg-blue-50 flex items-center justify-center flex-shrink-0 overflow-hidden">
          <% if(item.image){ %><img src="<%= item.image %>" class="w-full h-full object-contain"><% }else{ %><span class="text-blue-200 text-lg">👑</span><% } %>
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-semibold text-gray-900 text-sm"><%= item.name %></div>
          <% if(item.description){ %><div class="text-xs text-blue-500 mt-0.5">→ <%= item.description %></div><% } %>
        </div>
        <div class="text-sm text-gray-400 flex-shrink-0 w-16 text-right"><%= item.quantity||1 %> <%= item.unit||'шт' %></div>
        <div class="text-sm text-gray-400 flex-shrink-0 w-24 text-right"><%= fmt(item.price) %> ₽</div>
        <div class="text-sm font-bold text-gray-900 flex-shrink-0 w-24 text-right"><%= fmt((item.quantity||1)*item.price) %> ₽</div>
      </div>
      <% }); }); %>
      <% if(p.premiumPipingMaterialName){ %>
      <div class="flex justify-between items-center px-5 py-3 text-sm" style="background:#eff6ff">
        <span class="text-gray-500">Обвязка: <span class="font-semibold text-blue-700"><%= p.premiumPipingMaterialName %></span></span>
        <span class="font-bold text-blue-900"><%= fmt(p.premiumPipingPrice) %> ₽</span>
      </div>
      <% } %>
    </div>
    <div style="background:#1e3a8a">
      <div class="px-5 pt-4 space-y-1.5">
        <% if(p.premiumEquipmentTotal>0){ %><div class="flex justify-between text-sm text-blue-200"><span>Оборудование</span><span><%= fmt(p.premiumEquipmentTotal) %> ₽</span></div><% } %>
        <% if(p.premiumPipingPrice>0){ %><div class="flex justify-between text-sm text-blue-200"><span>Обвязка</span><span><%= fmt(p.premiumPipingPrice) %> ₽</span></div><% } %>
        <% if(p.premiumServicesTotal>0){ %><div class="flex justify-between text-sm text-blue-200"><span>Монтаж</span><span><%= fmt(p.premiumServicesTotal) %> ₽</span></div><% } %>
        <% if(p.premiumNotes){ %><div class="text-xs italic pb-1 text-blue-300"><%= p.premiumNotes %></div><% } %>
      </div>
      <div class="flex justify-between items-center px-5 py-4 border-t border-blue-800">
        <span class="text-sm font-bold uppercase tracking-widest text-blue-200">Итого Премиум вариант</span>
        <span class="text-3xl font-black text-white"><%= fmt(p.premiumTotal||0) %> ₽</span>
      </div>
    </div>
  </div>
  <% } %>


  <!-- ── РЕКОМЕНДУЕМЫЕ ДОПОЛНЕНИЯ ── -->
  <% if(opts.length>0){ %>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="sec-title">Рекомендуемые дополнения · не входят в стоимость</div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <% opts.forEach(function(opt){ var ico=optIcons[opt.code]||'📦'; %>
      <div class="border border-gray-200 rounded-xl overflow-hidden flex hover:border-gray-300 transition-colors">
        <% if(opt.image){ %>
          <img src="<%= opt.image %>" class="w-20 h-20 object-cover flex-shrink-0" alt="<%= opt.name %>">
        <% }else{ %>
          <div class="w-20 h-20 flex-shrink-0 bg-gray-50 flex items-center justify-center text-3xl border-r border-gray-100"><%= ico %></div>
        <% } %>
        <div class="p-3 flex-1 min-w-0">
          <div class="font-bold text-sm text-gray-900 mb-1"><%= opt.name %></div>
          <% if(opt.description){ %><div class="text-xs text-gray-500 leading-tight mb-2"><%= opt.description %></div><% } %>
          <div class="font-black text-sm text-gray-900"><%= fmt(opt.price||0) %> ₽</div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- ── УСЛОВИЯ ── -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
    <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
      <div class="text-2xl mb-2">💳</div>
      <div class="text-xs font-bold uppercase tracking-wide text-gray-400 mb-1">Оплата</div>
      <div class="font-bold text-sm text-gray-900"><%= p.paymentTermsText||'По согласованию' %></div>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
      <div class="text-2xl mb-2">🚚</div>
      <div class="text-xs font-bold uppercase tracking-wide text-gray-400 mb-1">Доставка</div>
      <div class="font-bold text-sm text-gray-900"><%= p.deliveryTimeText||'По согласованию' %></div>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
      <div class="text-2xl mb-2">🔧</div>
      <div class="text-xs font-bold uppercase tracking-wide text-gray-400 mb-1">Монтаж</div>
      <div class="font-bold text-sm text-gray-900"><%= p.installationTimeText||'—' %></div>
    </div>
  </div>

  <!-- ── ГАРАНТИИ ── -->
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="sec-title">Гарантийные обязательства</div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <% [['Гарантия на оборудование', p.warrantyEquipment||24],['Гарантия на монтаж', p.warrantyInstallation||24],['Гарантия на воду', p.warrantyWater||12]].forEach(function(w){ %>
      <div class="text-center border border-gray-100 rounded-xl p-4 bg-gray-50">
        <div class="text-xs font-bold uppercase tracking-wide text-gray-500 mb-3"><%= w[0] %></div>
        <div class="text-4xl font-black text-gray-900 leading-none"><%= w[1] %></div>
        <div class="text-sm text-gray-500 mt-2">месяцев</div>
      </div>
      <% }); %>
    </div>
  </div>

  <!-- ── ВКЛЮЧЕНО ── -->
  <% if(incs.length>0){ %>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="sec-title">Включено в стоимость</div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
      <% incs.forEach(function(inc){ %>
      <div class="flex items-center gap-2 text-sm text-gray-700">
        <div class="w-1.5 h-1.5 rounded-full bg-gray-900 flex-shrink-0"></div>
        <%= inc %>
      </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- ── ТЕХН. УСЛОВИЯ + ОБСЛУЖИВАНИЕ ── -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <div class="sec-title">Условия эксплуатации</div>
      <div class="space-y-2 text-sm">
        <% [['Давление на входе (min)','2.5 атм'],['Давление на входе (max)','5 атм'],['Электрическая сеть','220 В'],['Температура воздуха','5 – 35 °С'],['Наличие канализации','Обязательно'],['Прямые солнечные лучи','Не допускаются']].forEach(function(r){ %>
        <div class="flex justify-between py-1.5 border-b border-gray-100 last:border-0">
          <span class="text-gray-500"><%= r[0] %></span>
          <span class="font-semibold text-gray-900"><%= r[1] %></span>
        </div>
        <% }); %>
      </div>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <div class="sec-title">Периодичность обслуживания</div>
      <div class="space-y-2 text-sm">
        <% [['Замена сорбентов','1 раз в 2 года'],['Замена смолы','1 раз в 5–7 лет'],['Таблетированная соль','~1 мешок в месяц'],['Угольный картридж','1 раз в 6+ мес.'],['Плановое ТО','1 раз в год']].forEach(function(r){ %>
        <div class="flex justify-between py-1.5 border-b border-gray-100 last:border-0">
          <span class="text-gray-500"><%= r[0] %></span>
          <span class="font-semibold text-gray-900"><%= r[1] %></span>
        </div>
        <% }); %>
        <div class="text-xs text-gray-400 italic mt-2">* Сроки зависят от качества исходной воды</div>
      </div>
    </div>
  </div>

  <!-- ── ФОТО РАБОТ ── -->
  <% if(p.workPhotos&&p.workPhotos.length>0){ %>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="sec-title">Примеры выполненных работ</div>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <% p.workPhotos.forEach(function(photo){ %><img src="<%= photo %>" alt="Работа" class="rounded-xl border border-gray-100 w-full h-44 object-cover"><% }); %>
    </div>
  </div>
  <% } %>

  <!-- ── ПРИМЕЧАНИЯ ── -->
  <% if(p.notes){ %>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="sec-title">Примечания</div>
    <div class="text-sm text-gray-600 leading-relaxed bg-gray-50 rounded-lg p-4 border border-gray-100"><%= p.notes %></div>
  </div>
  <% } %>

  <!-- ── МЕНЕДЖЕР ── -->
  <% if(p.managerName){ %>
  <div class="bg-gray-50 rounded-xl border border-gray-200 p-5 flex items-center gap-4">
    <div class="w-12 h-12 rounded-full flex items-center justify-center text-xl font-black text-white flex-shrink-0" style="background:#111827">
      <%= p.managerName.charAt(0).toUpperCase() %>
    </div>
    <div>
      <div class="font-bold text-gray-900"><%= p.managerName %></div>
      <div class="text-xs text-gray-400 mb-1">Персональный менеджер</div>
      <div class="flex gap-4 text-sm">
        <% if(p.managerPhone){ %><a href="tel:<%= p.managerPhone %>" class="text-gray-700 hover:text-gray-900 font-medium flex items-center gap-1"><i data-lucide="phone" class="w-3.5 h-3.5"></i><%= p.managerPhone %></a><% } %>
        <% if(p.managerEmail){ %><a href="mailto:<%= p.managerEmail %>" class="text-gray-700 hover:text-gray-900 flex items-center gap-1"><i data-lucide="mail" class="w-3.5 h-3.5"></i><%= p.managerEmail %></a><% } %>
      </div>
    </div>
  </div>
  <% } %>

  <!-- ── РЕКВИЗИТЫ КОМПАНИИ ── -->
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="sec-title">Реквизиты компании</div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-2 text-sm">
      <% var reqRows = [
        ['Наименование', company.fullName||company.name||'ООО "Нова Фильтр"'],
        ['ИНН', company.inn||'7622019627'],
        ['КПП', company.kpp||'762201001'],
        ['Банк', company.bank||'Альфа-Банк'],
        ['Телефон', company.phone||'8 966-199-97-63'],
        ['Email', company.email||'info@nova-filter.ru'],
        ['Сайт', company.website||'www.nova-filter.ru']
      ];
      if(company.ogrn){ reqRows.splice(3,0,['ОГРН', company.ogrn]); }
      if(company.address){ reqRows.splice(1,0,['Адрес', company.address]); }
      %>
      <% reqRows.forEach(function(r){ %>
      <div class="flex gap-2 py-1.5 border-b border-gray-100 last:border-0">
        <span class="text-gray-400 w-28 flex-shrink-0"><%= r[0] %></span>
        <span class="font-semibold text-gray-800"><%= r[1] %></span>
      </div>
      <% }); %>
    </div>
  </div>

  <!-- ── ПАНЕЛЬ УПРАВЛЕНИЯ СТАТУСОМ (только для admin/manager) ── -->
  <% if(canSetStatus){ %>
  <div class="no-print bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100 flex items-center gap-2" style="background:#f9fafb">
      <i data-lucide="sliders" class="w-4 h-4 text-gray-500"></i>
      <span class="text-sm font-bold text-gray-700">Управление КП</span>
      <span class="ml-auto text-xs text-gray-400">Текущий статус:</span>
      <span class="px-2 py-0.5 rounded-full text-xs font-semibold <%= statusColor %>"><%= statusLabel %></span>
    </div>
    <div class="p-4 space-y-3">

      <!-- Строка 1: основные действия -->
      <div class="flex flex-wrap gap-2">
        <% if(canEdit){ %>
        <a href="/admin/proposals/<%= p._id %>/edit"
           class="px-4 py-2 border border-gray-200 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 flex items-center gap-1.5 transition">
          <i data-lucide="edit-2" class="w-3.5 h-3.5"></i> Редактировать
        </a>
        <% } %>
        <a href="/admin/proposals/<%= p._id %>/pdf" target="_blank"
           class="px-4 py-2 border border-gray-200 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 flex items-center gap-1.5 transition">
          <i data-lucide="printer" class="w-3.5 h-3.5"></i> PDF / Печать
        </a>
        <% if(canSend){ %>
        <form method="POST" action="/admin/proposals/<%= p._id %>/send" class="inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 flex items-center gap-1.5 transition">
            <i data-lucide="send" class="w-3.5 h-3.5"></i> Отправить клиенту
          </button>
        </form>
        <% } %>
        <% if(canDelete){ %>
        <form method="POST" action="/admin/proposals/<%= p._id %>/delete" class="inline" onsubmit="return confirm('Удалить КП?')">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="px-4 py-2 text-red-500 border border-red-100 rounded-lg text-sm font-medium hover:bg-red-50 flex items-center gap-1.5 transition">
            <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Удалить
          </button>
        </form>
        <% } %>
      </div>

      <!-- Строка 2: смена статуса -->
      <div class="border-t border-gray-100 pt-3">
        <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Изменить статус</div>
        <div class="flex flex-wrap gap-2">

          <!-- Принять (стандарт) -->
          <% if(!['accepted','accepted_premium','installed'].includes(p.status)){ %>
          <form method="POST" action="/admin/proposals/<%= p._id %>/status" class="inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="status" value="accepted">
            <button type="submit" class="px-3 py-1.5 bg-green-600 text-white rounded-lg text-xs font-semibold hover:bg-green-700 flex items-center gap-1 transition">
              <i data-lucide="check-circle" class="w-3.5 h-3.5"></i> Принято (стандарт)
            </button>
          </form>
          <% } %>

          <!-- Принять (премиум) — только если есть premiumItems -->
          <% if(p.premiumItems&&p.premiumItems.length>0&&!['accepted','accepted_premium','installed'].includes(p.status)){ %>
          <form method="POST" action="/admin/proposals/<%= p._id %>/status" class="inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="status" value="accepted_premium">
            <button type="submit" class="px-3 py-1.5 bg-amber-500 text-white rounded-lg text-xs font-semibold hover:bg-amber-600 flex items-center gap-1 transition">
              <i data-lucide="crown" class="w-3.5 h-3.5"></i> Принято (премиум)
            </button>
          </form>
          <% } %>

          <!-- В работе -->
          <% if(['accepted','accepted_premium'].includes(p.status)){ %>
          <form method="POST" action="/admin/proposals/<%= p._id %>/status" class="inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="status" value="in_progress">
            <button type="submit" class="px-3 py-1.5 bg-indigo-600 text-white rounded-lg text-xs font-semibold hover:bg-indigo-700 flex items-center gap-1 transition">
              <i data-lucide="wrench" class="w-3.5 h-3.5"></i> В работе
            </button>
          </form>
          <% } %>

          <!-- Смонтировано — открываем модал -->
          <% if(['accepted','accepted_premium','in_progress'].includes(p.status)){ %>
          <button onclick="document.getElementById('installModal').classList.remove('hidden')"
                  class="px-3 py-1.5 text-white rounded-lg text-xs font-semibold flex items-center gap-1 transition"
                  style="background:#111827">
            <i data-lucide="home" class="w-3.5 h-3.5"></i> Смонтировано ✓
          </button>
          <% } %>

          <!-- Отклонено -->
          <% if(!['rejected','installed','expired'].includes(p.status)){ %>
          <button onclick="document.getElementById('rejectModal').classList.remove('hidden')"
                  class="px-3 py-1.5 bg-red-50 text-red-600 border border-red-200 rounded-lg text-xs font-semibold hover:bg-red-100 flex items-center gap-1 transition">
            <i data-lucide="x-circle" class="w-3.5 h-3.5"></i> Отклонено
          </button>
          <% } %>
        </div>
      </div>

      <!-- Выбранный вариант (если принят) -->
      <% if(['accepted','accepted_premium','in_progress','installed'].includes(p.status)){ %>
      <div class="border-t border-gray-100 pt-3 flex items-center gap-3">
        <div class="text-xs text-gray-500">Выбранный вариант:</div>
        <%
          var variantCls = p.acceptedVariant==='premium' ? 'bg-amber-100 text-amber-800' : 'bg-gray-100 text-gray-700';
          var variantTxt = p.acceptedVariant==='premium' ? '👑 Премиум' : '📦 Стандарт';
        %>
        <span class="px-2 py-1 rounded-lg text-xs font-bold <%= variantCls %>">
          <%= variantTxt %>
        </span>
        <div class="text-xs text-gray-500">Сумма сделки:</div>
        <div class="font-black text-sm text-gray-900"><%= (p.acceptedAmount||p.totalPrice||0).toLocaleString('ru-RU') %> ₽</div>
      </div>
      <% } %>

      <!-- Монтаж завершён -->
      <% if(p.status==='installed'&&p.installedAt){ %>
      <div class="border-t border-gray-100 pt-3 flex items-center gap-2 text-xs text-gray-500">
        <i data-lucide="check-circle" class="w-4 h-4 text-emerald-500"></i>
        <span>Смонтировано <b><%= new Date(p.installedAt).toLocaleDateString('ru-RU') %></b></span>
        <% if(p.installNotes){ %><span class="ml-2 text-gray-400">— <%= p.installNotes %></span><% } %>
      </div>
      <% } %>

    </div>
  </div>
  <% } %>

  <!-- Кнопки для клиента -->
  <% if(canAccept){ %>
  <div class="no-print bg-white rounded-xl border border-gray-200 p-4 flex flex-wrap gap-3">
    <form method="POST" action="/proposals/<%= p._id %>/accept" class="inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="px-5 py-2.5 bg-green-600 text-white rounded-xl hover:bg-green-700 font-semibold flex items-center gap-2">
        <i data-lucide="check" class="w-4 h-4"></i> Принять предложение
      </button>
    </form>
    <form method="POST" action="/proposals/<%= p._id %>/reject" class="inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="flex gap-2 items-center">
        <input type="text" name="reason" placeholder="Причина отказа..." class="px-3 py-2.5 border rounded-xl text-sm">
        <button type="submit" class="px-4 py-2.5 bg-red-50 text-red-700 border border-red-200 rounded-xl font-medium text-sm">
          <i data-lucide="x" class="w-4 h-4 inline"></i> Отклонить
        </button>
      </div>
    </form>
  </div>
  <% } %>

  <!-- Модал: Смонтировано -->
  <div id="installModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
      <h3 class="font-bold text-lg mb-4 flex items-center gap-2">
        <i data-lucide="home" class="w-5 h-5 text-emerald-600"></i> Подтвердить монтаж
      </h3>
      <form method="POST" action="/admin/proposals/<%= p._id %>/status">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="status" value="installed">
        <div class="mb-4">
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Примечания по монтажу</label>
          <textarea name="installNotes" rows="3" placeholder="Особенности монтажа, отступления от проекта..."
            class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm resize-none focus:ring-2 focus:ring-emerald-500"></textarea>
        </div>
        <div class="flex gap-3 justify-end">
          <button type="button" onclick="document.getElementById('installModal').classList.add('hidden')"
            class="px-4 py-2 border border-gray-200 rounded-xl text-sm font-medium hover:bg-gray-50">Отмена</button>
          <button type="submit"
            class="px-5 py-2 bg-emerald-600 text-white rounded-xl text-sm font-semibold hover:bg-emerald-700 flex items-center gap-2">
            <i data-lucide="check" class="w-4 h-4"></i> Подтвердить
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Модал: Отклонено -->
  <div id="rejectModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
      <h3 class="font-bold text-lg mb-4 flex items-center gap-2">
        <i data-lucide="x-circle" class="w-5 h-5 text-red-500"></i> Отклонить КП
      </h3>
      <form method="POST" action="/admin/proposals/<%= p._id %>/status">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="status" value="rejected">
        <div class="mb-4">
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Причина отказа</label>
          <input type="text" name="reason" placeholder="Клиент выбрал другого подрядчика..."
            class="w-full px-3 py-2 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-red-400">
        </div>
        <div class="flex gap-3 justify-end">
          <button type="button" onclick="document.getElementById('rejectModal').classList.add('hidden')"
            class="px-4 py-2 border border-gray-200 rounded-xl text-sm font-medium hover:bg-gray-50">Отмена</button>
          <button type="submit"
            class="px-5 py-2 bg-red-600 text-white rounded-xl text-sm font-semibold hover:bg-red-700">
            Отклонить
          </button>
        </div>
      </form>
    </div>
  </div>

</div>
