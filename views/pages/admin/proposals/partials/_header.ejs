<%
  var typeTitle = (typeof currentType !== 'undefined' && typeof typeLabels !== 'undefined') 
    ? typeLabels[currentType] || 'Создать КП' 
    : 'Создать КП';
%>

<div class="bg-white rounded-xl border shadow-sm p-6 mb-6">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-4">
      <a href="/admin/proposals" class="p-2 hover:bg-gray-100 rounded-lg transition-colors">
        <i data-lucide="arrow-left" class="w-5 h-5 text-gray-600"></i>
      </a>
      <div>
        <h1 class="text-2xl font-bold text-gray-900"><%= typeTitle %></h1>
        <p class="text-sm text-gray-500 mt-1">Заполните все шаги для создания коммерческого предложения</p>
      </div>
    </div>
    
    <div class="flex items-center gap-2">
      <div class="px-3 py-1.5 bg-blue-100 text-blue-700 rounded-lg text-sm font-medium">
        Черновик
      </div>
    </div>
  </div>
</div>
