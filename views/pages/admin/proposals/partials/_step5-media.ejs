<%
  var safeSchemes = (typeof schemesList !== 'undefined' && Array.isArray(schemesList)) ? schemesList : [];
  var safeWorkPhotos = (typeof workPhotosList !== 'undefined' && Array.isArray(workPhotosList)) ? workPhotosList : [];
%>

<div id="step5" class="step-content">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    
    <!-- Техническая схема -->
    <div class="bg-white rounded-xl border shadow-sm p-6">
      <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
        <i data-lucide="layout" class="w-5 h-5 text-blue-500"></i>
        Техническая схема
      </h3>
      
      <div id="schemaUploadArea" class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center cursor-pointer hover:border-blue-400 hover:bg-blue-50 transition-all">
        <i data-lucide="upload" class="w-12 h-12 mx-auto mb-3 text-gray-400"></i>
        <p class="text-sm font-medium text-gray-700">Нажмите для загрузки схемы</p>
        <p class="text-xs text-gray-500 mt-1">PNG, JPG до 5MB</p>
      </div>
      <input type="file" id="schemaInput" name="schemaImageUpload" accept="image/*" class="hidden">
      
      <div id="schemaPreview" class="mt-4 hidden"></div>
      <input type="hidden" id="schemaImageHidden" name="schemaImage">
      
      <% if (safeSchemes.length > 0) { %>
        <div class="mt-6">
          <p class="text-sm font-medium mb-3 text-gray-700">Или выберите из галереи:</p>
          <div class="grid grid-cols-3 gap-3">
            <% safeSchemes.forEach(function(src) { %>
              <div class="scheme-thumb cursor-pointer border-2 border-gray-200 rounded-lg overflow-hidden hover:border-blue-400 transition-all"
                   data-src="<%= src %>">
                <img src="<%= src %>" class="w-full h-24 object-cover">
              </div>
            <% }); %>
          </div>
        </div>
      <% } else { %>
        <div class="mt-4 text-center py-4">
          <p class="text-sm text-gray-500">Галерея схем пуста</p>
        </div>
      <% } %>
    </div>
    
    <!-- Фото работ -->
    <div class="bg-white rounded-xl border shadow-sm p-6">
      <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
        <i data-lucide="image" class="w-5 h-5 text-blue-500"></i>
        Фото выполненных работ
      </h3>
      
      <div id="photosUploadArea" class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center cursor-pointer hover:border-blue-400 hover:bg-blue-50 transition-all">
        <i data-lucide="images" class="w-12 h-12 mx-auto mb-3 text-gray-400"></i>
        <p class="text-sm font-medium text-gray-700">Нажмите для загрузки фото</p>
        <p class="text-xs text-gray-500 mt-1">До 5 файлов, PNG/JPG до 5MB каждый</p>
      </div>
      <input type="file" id="workPhotosInput" name="workPhotosUpload" accept="image/*" multiple class="hidden">
      
      <div id="workPhotosPreview" class="mt-4 flex flex-wrap gap-2"></div>
      
      <% if (safeWorkPhotos.length > 0) { %>
        <div class="mt-6">
          <p class="text-sm font-medium mb-3 text-gray-700">Или выберите из галереи (до 5):</p>
          <div class="grid grid-cols-4 gap-2">
            <% safeWorkPhotos.forEach(function(src) { %>
              <div class="photo-thumb cursor-pointer border-2 border-gray-200 rounded-lg overflow-hidden hover:border-blue-400 transition-all"
                   data-src="<%= src %>">
                <img src="<%= src %>" class="w-full h-20 object-cover">
              </div>
            <% }); %>
          </div>
        </div>
      <% } else { %>
        <div class="mt-4 text-center py-4">
          <p class="text-sm text-gray-500">Галерея фото пуста</p>
        </div>
      <% } %>
      
      <div class="mt-6 p-4 bg-blue-50 border border-blue-200 rounded-lg">
        <div class="flex gap-2">
          <i data-lucide="info" class="w-5 h-5 text-blue-600 flex-shrink-0"></i>
          <div class="text-sm text-blue-800">
            <p class="font-medium">Зачем нужны фото работ?</p>
            <p class="mt-1">Демонстрация ваших выполненных проектов повышает доверие клиента</p>
          </div>
        </div>
      </div>
    </div>
    
  </div>
</div>
