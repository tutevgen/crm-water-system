<div id="catalogModal" class="modal-overlay">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-5xl max-h-[90vh] overflow-hidden flex flex-col">
    
    <!-- Заголовок -->
    <div class="p-6 border-b flex items-center justify-between">
      <h2 class="text-xl font-bold flex items-center gap-2">
        <i data-lucide="package" class="w-6 h-6 text-blue-500"></i>
        Каталог товаров
      </h2>
      <button type="button" class="modal-close p-2 hover:bg-gray-100 rounded-lg transition-colors">
        <i data-lucide="x" class="w-5 h-5 text-gray-500"></i>
      </button>
    </div>
    
    <!-- Поиск -->
    <div class="p-6 border-b">
      <div class="relative">
        <i data-lucide="search" class="w-5 h-5 absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
        <input type="text" 
               id="catalogSearch" 
               placeholder="Поиск по названию или артикулу..."
               class="w-full pl-10 pr-4 py-3 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
      </div>
    </div>
    
    <!-- Сетка товаров -->
    <div class="flex-1 overflow-y-auto p-6">
      <div id="catalogGrid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <!-- Товары добавляются через JavaScript -->
      </div>
    </div>
    
    <!-- Подвал -->
    <div class="p-6 border-t bg-gray-50">
      <div class="flex items-center justify-between text-sm text-gray-600">
        <p>Нажмите на товар чтобы добавить его в КП</p>
        <button type="button" class="modal-close text-blue-600 hover:text-blue-700 font-medium">
          Закрыть
        </button>
      </div>
    </div>
    
  </div>
</div>
