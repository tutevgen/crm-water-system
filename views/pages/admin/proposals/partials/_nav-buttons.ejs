<div class="mt-8 flex items-center justify-between">
  <button type="button" id="btnPrev" 
          class="hidden px-6 py-3 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 font-medium transition-colors flex items-center gap-2">
    <i data-lucide="arrow-left" class="w-4 h-4"></i>
    Назад
  </button>
  
  <div class="flex-1"></div>
  
  <button type="button" id="btnNext"
          class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium transition-colors flex items-center gap-2">
    Далее
    <i data-lucide="arrow-right" class="w-4 h-4"></i>
  </button>
  
  <button type="submit" id="btnSubmit"
          class="hidden px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 font-medium transition-colors flex items-center gap-2">
    <i data-lucide="check" class="w-4 h-4"></i>
    Создать КП
  </button>
</div>
