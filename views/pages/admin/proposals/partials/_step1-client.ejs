<div id="step1" class="step-content active">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    
    <!-- Клиент -->
    <div class="lg:col-span-2 bg-white rounded-xl border shadow-sm p-6">
      <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
        <i data-lucide="user" class="w-5 h-5 text-blue-500"></i>
        Клиент
      </h2>
      
      <!-- Переключатель -->
      <div class="flex gap-4 mb-4 p-3 bg-gray-50 rounded-lg">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="clientType" value="existing" checked class="text-blue-600">
          <span class="text-sm">Из базы</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="clientType" value="new" class="text-blue-600">
          <span class="text-sm">Новый клиент</span>
        </label>
      </div>
      
      <!-- Из базы -->
      <div id="existingClientSection">
        <div class="relative mb-4">
          <i data-lucide="search" class="w-5 h-5 absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
          <input type="text" id="clientSearch" placeholder="Поиск по имени или телефону..."
                 class="w-full pl-10 pr-4 py-2.5 border rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
        </div>
        
        <div id="clientsList" class="space-y-2 max-h-64 overflow-y-auto">
          <% 
            // Безопасная проверка переменной
            var safeClientsList = (typeof clientsList !== 'undefined' && Array.isArray(clientsList)) ? clientsList : [];
          %>
          
          <% if (safeClientsList.length === 0) { %>
            <div class="text-center py-8 text-gray-500">
              <i data-lucide="users" class="w-12 h-12 mx-auto mb-2 text-gray-300"></i>
              <p>Клиенты не найдены</p>
              <p class="text-sm mt-1">Создайте нового клиента ниже</p>
            </div>
          <% } else { %>
            <% safeClientsList.forEach(function(c) { %>
              <label class="flex items-center gap-3 p-3 border rounded-lg cursor-pointer hover:bg-gray-50 client-option"
                     data-name="<%= (c.name || '').toLowerCase() %>" 
                     data-phone="<%= c.phone || '' %>">
                <input type="radio" name="clientId" value="<%= c._id %>" class="text-blue-600"
                       data-discount="<%= c.discount || 0 %>"
                       data-address="<%= c.address || '' %>">
                <div class="flex-1 min-w-0">
                  <div class="font-medium truncate"><%= c.name || 'Без имени' %></div>
                  <div class="text-sm text-gray-500"><%= c.phone || '' %></div>
                  <% if (c.address) { %>
                    <div class="text-xs text-gray-400 truncate"><%= c.address %></div>
                  <% } %>
                </div>
                <% if (c.discount && c.discount > 0) { %>
                  <span class="px-2 py-0.5 bg-green-100 text-green-700 text-xs rounded-full flex-shrink-0">
                    -<%= c.discount %>%
                  </span>
                <% } %>
              </label>
            <% }); %>
          <% } %>
        </div>
      </div>
      
      <!-- Новый клиент -->
      <div id="newClientSection" class="hidden space-y-3">
        <div>
          <label class="block text-sm font-medium mb-1">Имя *</label>
          <input type="text" name="newClientName" placeholder="Иван Иванов"
                 class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Телефон *</label>
          <input type="tel" name="newClientPhone" placeholder="+7 999 123-45-67"
                 class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Email</label>
          <input type="email" name="newClientEmail" placeholder="client@example.com"
                 class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500">
        </div>
      </div>
    </div>
    
    <!-- Справка -->
    <div class="bg-blue-50 rounded-xl border border-blue-200 p-6">
      <h3 class="font-semibold text-blue-900 mb-3 flex items-center gap-2">
        <i data-lucide="info" class="w-5 h-5"></i>
        Подсказка
      </h3>
      <div class="text-sm text-blue-800 space-y-2">
        <p>• Выберите клиента из базы или создайте нового</p>
        <p>• Клиентская скидка применится автоматически</p>
        <p>• Телефон станет логином для входа</p>
      </div>
      
      <div class="mt-4 pt-4 border-t border-blue-200">
        <div class="text-xs text-blue-700">
          <div class="flex justify-between mb-1">
            <span>Всего клиентов:</span>
            <span class="font-semibold"><%= safeClientsList.length %></span>
          </div>
        </div>
      </div>
    </div>
    
  </div>
  
  <!-- Скрытое поле для скидки клиента -->
  <input type="hidden" id="clientDiscountInput" name="clientDiscount" value="0">
</div>
