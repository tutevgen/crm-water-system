<%# views/pages/admin/proposals.ejs %>

<% layout('layouts/default') %>

<%
  var proposalsList = typeof proposals !== 'undefined' ? proposals : [];
  var pag = typeof pagination !== 'undefined' ? pagination : { page: 1, total: 0, totalPages: 0 };
  var f = typeof filters !== 'undefined' ? filters : {};
  
  var statusColors = {
    draft:            'bg-gray-100 text-gray-700',
    sent:             'bg-blue-100 text-blue-700',
    viewed:           'bg-purple-100 text-purple-700',
    accepted:         'bg-green-100 text-green-700',
    accepted_premium: 'bg-amber-100 text-amber-800',
    in_progress:      'bg-indigo-100 text-indigo-700',
    installed:        'bg-emerald-100 text-emerald-700',
    rejected:         'bg-red-100 text-red-700',
    expired:          'bg-yellow-100 text-yellow-700'
  };
  var statusNames = {
    draft:            'Черновик',
    sent:             'Отправлено',
    viewed:           'Просмотрено',
    accepted:         'Принято',
    accepted_premium: 'Принято (премиум)',
    in_progress:      'В работе',
    installed:        'Смонтировано',
    rejected:         'Отклонено',
    expired:          'Истекло'
  };
%>

<div class="p-4 md:p-6 space-y-6">
  
  <!-- Заголовок -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Коммерческие предложения</h1>
      <p class="text-gray-500 mt-1">Всего: <%= pag.total %></p>
    </div>
    
    <a href="/admin/proposals/create" class="inline-flex items-center gap-2 px-4 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
      <i data-lucide="plus" class="w-5 h-5"></i>
      Создать КП
    </a>
  </div>

  <!-- Фильтры -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
    <form method="GET" class="flex flex-wrap items-end gap-4">
      <!-- Поиск -->
      <div class="flex-1 min-w-[200px]">
        <label class="block text-sm font-medium text-gray-700 mb-1">Поиск</label>
        <div class="relative">
          <input type="text" name="search" value="<%= f.search || '' %>" 
            placeholder="Номер КП или имя клиента..." 
            class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
          <i data-lucide="search" class="w-5 h-5 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2"></i>
        </div>
      </div>
      
      <!-- Статус -->
      <div class="w-48">
        <label class="block text-sm font-medium text-gray-700 mb-1">Статус</label>
        <select name="status" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
          <option value="all">Все статусы</option>
          <option value="draft"            <%= f.status === 'draft'            ? 'selected' : '' %>>Черновики</option>
          <option value="sent"             <%= f.status === 'sent'             ? 'selected' : '' %>>Отправленные</option>
          <option value="viewed"           <%= f.status === 'viewed'           ? 'selected' : '' %>>Просмотренные</option>
          <option value="accepted"         <%= f.status === 'accepted'         ? 'selected' : '' %>>Принятые (стандарт)</option>
          <option value="accepted_premium" <%= f.status === 'accepted_premium' ? 'selected' : '' %>>Принятые (премиум)</option>
          <option value="in_progress"      <%= f.status === 'in_progress'      ? 'selected' : '' %>>В работе</option>
          <option value="installed"        <%= f.status === 'installed'        ? 'selected' : '' %>>Смонтированные</option>
          <option value="rejected"         <%= f.status === 'rejected'         ? 'selected' : '' %>>Отклонённые</option>
          <option value="expired"          <%= f.status === 'expired'          ? 'selected' : '' %>>Истёкшие</option>
        </select>
      </div>
      
      <button type="submit" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors">
        <i data-lucide="filter" class="w-4 h-4 inline mr-1"></i>
        Применить
      </button>
      
      <a href="/admin/proposals" class="px-4 py-2 text-gray-500 hover:text-gray-700">
        Сбросить
      </a>
    </form>
  </div>

  <!-- Таблица -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <% if (proposalsList.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">№ КП</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Клиент</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Сумма</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Статус</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Создано</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Действует до</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Действия</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% proposalsList.forEach(function(p) { %>
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-3">
                  <a href="/admin/proposals/<%= p._id %>" class="font-medium text-blue-600 hover:underline">
                    <%= p.proposalNumber %>
                  </a>
                </td>
                <td class="px-4 py-3">
                  <div class="font-medium text-gray-900"><%= p.clientName || (p.clientId && p.clientId.name) || '—' %></div>
                  <div class="text-sm text-gray-500"><%= p.clientEmail || (p.clientId && p.clientId.email) || p.clientPhone || '' %></div>
                </td>
                <td class="px-4 py-3">
                  <%
                    var displayAmount = p.acceptedAmount && p.acceptedAmount > 0
                      ? p.acceptedAmount
                      : (p.totalPrice || 0);
                  %>
                  <span class="font-semibold text-gray-900"><%= displayAmount.toLocaleString('ru-RU') %> ₽</span>
                  <% if(p.acceptedVariant === 'premium'){ %>
                  <div class="text-xs text-amber-600 font-medium">👑 Премиум</div>
                  <% } %>
                </td>
                <td class="px-4 py-3">
                  <span class="px-2.5 py-1 text-xs font-medium rounded-full <%= statusColors[p.status] || 'bg-gray-100 text-gray-700' %>">
                    <%= statusNames[p.status] || p.status %>
                  </span>
                </td>
                <td class="px-4 py-3 text-sm text-gray-500">
                  <%= p.createdAt ? new Date(p.createdAt).toLocaleDateString('ru-RU') : '—' %>
                </td>
                <td class="px-4 py-3 text-sm">
                  <% if (p.validUntil) { 
                    var isExpired = new Date(p.validUntil) < new Date();
                  %>
                    <span class="<%= isExpired ? 'text-red-600' : 'text-gray-500' %>">
                      <%= new Date(p.validUntil).toLocaleDateString('ru-RU') %>
                    </span>
                  <% } else { %>
                    —
                  <% } %>
                </td>
                <td class="px-4 py-3 text-right">
                  <div class="flex items-center justify-end gap-1">
                    <a href="/admin/proposals/<%= p._id %>" title="Просмотр" 
                      class="p-2 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">
                      <i data-lucide="eye" class="w-4 h-4"></i>
                    </a>
                    
                    <% if (p.status !== 'installed') { %>
                      <a href="/admin/proposals/<%= p._id %>/edit" title="Редактировать"
                        class="p-2 text-gray-400 hover:text-yellow-600 hover:bg-yellow-50 rounded-lg transition-colors">
                        <i data-lucide="edit" class="w-4 h-4"></i>
                      </a>
                    <% } %>
                    
                    <form action="/admin/proposals/<%= p._id %>/duplicate" method="POST" class="inline">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" title="Дублировать"
                        class="p-2 text-gray-400 hover:text-green-600 hover:bg-green-50 rounded-lg transition-colors">
                        <i data-lucide="copy" class="w-4 h-4"></i>
                      </button>
                    </form>
                    
                    <% if (!['installed','rejected','expired'].includes(p.status)) { %>
                      <form action="/admin/proposals/<%= p._id %>/send" method="POST" class="inline">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" title="Отправить клиенту"
                          class="p-2 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">
                          <i data-lucide="send" class="w-4 h-4"></i>
                        </button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      
      <!-- Пагинация -->
      <% if (pag.totalPages > 1) { %>
        <div class="px-4 py-3 border-t border-gray-200 flex items-center justify-between">
          <div class="text-sm text-gray-500">
            Показано <%= (pag.page - 1) * pag.limit + 1 %>-<%= Math.min(pag.page * pag.limit, pag.total) %> из <%= pag.total %>
          </div>
          
          <div class="flex items-center gap-1">
            <% if (pag.page > 1) { %>
              <a href="?page=<%= pag.page - 1 %>&status=<%= f.status || '' %>&search=<%= f.search || '' %>" 
                class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">
                ← Назад
              </a>
            <% } %>
            
            <% for (var i = Math.max(1, pag.page - 2); i <= Math.min(pag.totalPages, pag.page + 2); i++) { %>
              <a href="?page=<%= i %>&status=<%= f.status || '' %>&search=<%= f.search || '' %>" 
                class="px-3 py-1.5 border rounded-lg text-sm <%= i === pag.page ? 'bg-blue-600 text-white border-blue-600' : 'border-gray-300 hover:bg-gray-50' %>">
                <%= i %>
              </a>
            <% } %>
            
            <% if (pag.page < pag.totalPages) { %>
              <a href="?page=<%= pag.page + 1 %>&status=<%= f.status || '' %>&search=<%= f.search || '' %>" 
                class="px-3 py-1.5 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">
                Вперёд →
              </a>
            <% } %>
          </div>
        </div>
      <% } %>
      
    <% } else { %>
      <div class="p-12 text-center">
        <i data-lucide="file-x" class="w-16 h-16 text-gray-300 mx-auto mb-4"></i>
        <h3 class="text-lg font-medium text-gray-900 mb-2">Коммерческих предложений пока нет</h3>
        <p class="text-gray-500 mb-4">Создайте первое КП для клиента</p>
        <a href="/admin/proposals/create" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
          <i data-lucide="plus" class="w-4 h-4"></i>
          Создать КП
        </a>
      </div>
    <% } %>
  </div>
</div>

<script>
(function() {
  if (typeof lucide !== 'undefined') lucide.createIcons();
})();
</script>
