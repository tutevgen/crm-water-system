<%# views/pages/admin/clients.ejs %>

<% layout('layouts/default') %>

<div class="p-6">
  <!-- Flash сообщения -->
  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="mb-4 p-4 bg-green-50 border border-green-200 text-green-700 rounded-lg flex items-center gap-2">
      <i data-lucide="check-circle" class="w-5 h-5"></i>
      <%= Array.isArray(success) ? success.join(', ') : success %>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="mb-4 p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg flex items-center gap-2">
      <i data-lucide="alert-circle" class="w-5 h-5"></i>
      <%= Array.isArray(error) ? error.join(', ') : error %>
    </div>
  <% } %>

  <!-- Заголовок -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Клиенты</h1>
      <p class="text-sm text-gray-500 mt-1">
        Всего: <%= typeof stats !== 'undefined' ? stats.total : 0 %> клиентов
        <% if (typeof stats !== 'undefined' && stats.active) { %>
          <span class="text-green-600 ml-2">● <%= stats.active %> активных</span>
        <% } %>
      </p>
    </div>
    <div class="flex gap-3">
      <a href="/admin/clients/export" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 flex items-center gap-2">
        <i data-lucide="download" class="w-4 h-4"></i>
        Экспорт
      </a>
      <a href="/admin/clients/create" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 flex items-center gap-2">
        <i data-lucide="user-plus" class="w-4 h-4"></i>
        Добавить клиента
      </a>
    </div>
  </div>

  <!-- Статистика -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
      <div class="flex items-center gap-3">
        <div class="p-2 bg-blue-100 rounded-lg">
          <i data-lucide="users" class="w-5 h-5 text-blue-600"></i>
        </div>
        <div>
          <p class="text-2xl font-bold text-gray-900"><%= typeof stats !== 'undefined' ? stats.total : 0 %></p>
          <p class="text-xs text-gray-500">Всего</p>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
      <div class="flex items-center gap-3">
        <div class="p-2 bg-green-100 rounded-lg">
          <i data-lucide="user-check" class="w-5 h-5 text-green-600"></i>
        </div>
        <div>
          <p class="text-2xl font-bold text-gray-900"><%= typeof stats !== 'undefined' ? stats.active : 0 %></p>
          <p class="text-xs text-gray-500">Активных</p>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
      <div class="flex items-center gap-3">
        <div class="p-2 bg-purple-100 rounded-lg">
          <i data-lucide="building" class="w-5 h-5 text-purple-600"></i>
        </div>
        <div>
          <p class="text-2xl font-bold text-gray-900"><%= typeof stats !== 'undefined' ? stats.companies : 0 %></p>
          <p class="text-xs text-gray-500">Компаний</p>
        </div>
      </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
      <div class="flex items-center gap-3">
        <div class="p-2 bg-yellow-100 rounded-lg">
          <i data-lucide="calendar" class="w-5 h-5 text-yellow-600"></i>
        </div>
        <div>
          <p class="text-2xl font-bold text-gray-900"><%= typeof stats !== 'undefined' ? stats.thisMonth : 0 %></p>
          <p class="text-xs text-gray-500">За месяц</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Фильтры -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-6">
    <form method="GET" action="/admin/clients" id="filterForm">
      <div class="flex flex-wrap gap-4 items-end">
        
        <!-- Поиск -->
        <div class="flex-1 min-w-[250px]">
          <label class="block text-sm font-medium text-gray-700 mb-1">Поиск</label>
          <div class="relative">
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"></i>
            <input type="text" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>" 
              placeholder="Имя, email, телефон, компания..."
              class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
          </div>
        </div>
        
        <!-- Тип клиента -->
        <div class="w-44">
          <label class="block text-sm font-medium text-gray-700 mb-1">Тип</label>
          <select name="clientType" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
            <option value="">Все типы</option>
            <option value="individual" <%= typeof clientType !== 'undefined' && clientType === 'individual' ? 'selected' : '' %>>Физ. лица</option>
            <option value="company" <%= typeof clientType !== 'undefined' && clientType === 'company' ? 'selected' : '' %>>Юр. лица</option>
            <option value="ip" <%= typeof clientType !== 'undefined' && clientType === 'ip' ? 'selected' : '' %>>ИП</option>
          </select>
        </div>
        
        <!-- Статус -->
        <div class="w-40">
          <label class="block text-sm font-medium text-gray-700 mb-1">Статус</label>
          <select name="status" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
            <option value="">Все</option>
            <option value="active" <%= typeof status !== 'undefined' && status === 'active' ? 'selected' : '' %>>Активные</option>
            <option value="inactive" <%= typeof status !== 'undefined' && status === 'inactive' ? 'selected' : '' %>>Неактивные</option>
            <option value="new" <%= typeof status !== 'undefined' && status === 'new' ? 'selected' : '' %>>Новые (7 дней)</option>
          </select>
        </div>
        
        <!-- Менеджер -->
        <div class="w-48">
          <label class="block text-sm font-medium text-gray-700 mb-1">Менеджер</label>
          <select name="manager" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
            <option value="">Все менеджеры</option>
            <% if (typeof managers !== 'undefined' && managers.length > 0) { %>
              <% managers.forEach(function(m) { %>
                <option value="<%= m._id %>" <%= typeof manager !== 'undefined' && manager === m._id.toString() ? 'selected' : '' %>><%= m.name %></option>
              <% }); %>
            <% } %>
          </select>
        </div>
        
        <!-- Сортировка -->
        <div class="w-44">
          <label class="block text-sm font-medium text-gray-700 mb-1">Сортировка</label>
          <select name="sort" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
            <option value="">Новые первые</option>
            <option value="oldest" <%= typeof sort !== 'undefined' && sort === 'oldest' ? 'selected' : '' %>>Старые первые</option>
            <option value="name" <%= typeof sort !== 'undefined' && sort === 'name' ? 'selected' : '' %>>По имени А-Я</option>
            <option value="orders" <%= typeof sort !== 'undefined' && sort === 'orders' ? 'selected' : '' %>>По заказам</option>
            <option value="lastActivity" <%= typeof sort !== 'undefined' && sort === 'lastActivity' ? 'selected' : '' %>>По активности</option>
          </select>
        </div>
        
        <button type="submit" class="px-4 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-800 flex items-center gap-2">
          <i data-lucide="filter" class="w-4 h-4"></i>
          Применить
        </button>
        <a href="/admin/clients" class="px-4 py-2 text-gray-600 hover:text-gray-900">Сбросить</a>
      </div>
    </form>
  </div>

  <!-- Таблица клиентов -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <% 
      var clientsList = typeof clients !== 'undefined' && Array.isArray(clients) ? clients : [];
    %>
    <% if (clientsList.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Клиент</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Контакты</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Тип</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Менеджер</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-gray-600 uppercase">Заказы</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-gray-600 uppercase">Скидка</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-gray-600 uppercase">Статус</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase">Действия</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% clientsList.forEach(function(client) { 
              var isNew = client.createdAt && (new Date() - new Date(client.createdAt)) < 7 * 24 * 60 * 60 * 1000;
            %>
              <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='/admin/clients/<%= client._id %>'">
                <td class="px-4 py-3">
                  <div class="flex items-center gap-3">
                    <% if (client.avatar) { %>
                      <img src="/img/avatars/<%= client.avatar %>" alt="" class="w-10 h-10 rounded-full object-cover">
                    <% } else { %>
                      <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-medium">
                        <%= client.name ? client.name.charAt(0).toUpperCase() : '?' %>
                      </div>
                    <% } %>
                    <div>
                      <div class="font-medium text-gray-900 flex items-center gap-2">
                        <%= client.name || 'Без имени' %>
                        <% if (isNew) { %><span class="px-1.5 py-0.5 bg-green-100 text-green-700 text-xs rounded">NEW</span><% } %>
                        <% if (client.isVerified) { %><i data-lucide="badge-check" class="w-4 h-4 text-blue-500"></i><% } %>
                      </div>
                      <% if (client.companyDetails && client.companyDetails.fullName) { %>
                        <div class="text-xs text-gray-500"><%= client.companyDetails.fullName %></div>
                      <% } %>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <div class="text-sm">
                    <% if (client.email) { %>
                      <div class="flex items-center gap-1 text-gray-600">
                        <i data-lucide="mail" class="w-3 h-3"></i>
                        <%= client.email %>
                      </div>
                    <% } %>
                    <% if (client.phone) { %>
                      <div class="flex items-center gap-1 text-gray-600">
                        <i data-lucide="phone" class="w-3 h-3"></i>
                        <%= client.phone %>
                      </div>
                    <% } %>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <% 
                    var typeLabels = {
                      individual: { text: 'Физ. лицо', cls: 'bg-gray-100 text-gray-700' },
                      company: { text: 'Юр. лицо', cls: 'bg-purple-100 text-purple-700' },
                      ip: { text: 'ИП', cls: 'bg-blue-100 text-blue-700' }
                    };
                    var clientTypeInfo = client.companyDetails && client.companyDetails.clientType 
                      ? typeLabels[client.companyDetails.clientType] || typeLabels.individual
                      : typeLabels.individual;
                  %>
                  <span class="px-2 py-1 text-xs font-medium rounded <%= clientTypeInfo.cls %>"><%= clientTypeInfo.text %></span>
                </td>
                <td class="px-4 py-3 text-sm text-gray-600">
                  <%= client.manager ? client.manager.name : '—' %>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="font-medium text-gray-900"><%= client.ordersCount || 0 %></span>
                </td>
                <td class="px-4 py-3 text-center">
                  <% if (client.discount && client.discount > 0) { %>
                    <span class="px-2 py-1 bg-green-100 text-green-700 text-xs font-medium rounded"><%= client.discount %>%</span>
                  <% } else { %>
                    <span class="text-gray-400">—</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-center">
                  <% if (client.isActive !== false) { %>
                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-green-100 text-green-700 text-xs font-medium rounded">
                      <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                      Активен
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-gray-100 text-gray-600 text-xs font-medium rounded">
                      <span class="w-1.5 h-1.5 bg-gray-400 rounded-full"></span>
                      Неактивен
                    </span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-right" onclick="event.stopPropagation()">
                  <div class="flex justify-end gap-1">
                    <a href="/admin/clients/<%= client._id %>" class="p-2 text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg" title="Просмотр">
                      <i data-lucide="eye" class="w-4 h-4"></i>
                    </a>
                    <a href="/admin/clients/<%= client._id %>/edit" class="p-2 text-gray-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg" title="Редактировать">
                      <i data-lucide="pencil" class="w-4 h-4"></i>
                    </a>
                    <a href="/proposals/create?client=<%= client._id %>" class="p-2 text-gray-600 hover:text-purple-600 hover:bg-purple-50 rounded-lg" title="Создать КП">
                      <i data-lucide="file-text" class="w-4 h-4"></i>
                    </a>
                    <button type="button" data-toggle-status="<%= client._id %>" data-active="<%= client.isActive !== false %>"
                      class="p-2 text-gray-600 hover:text-yellow-600 hover:bg-yellow-50 rounded-lg" title="<%= client.isActive !== false ? 'Деактивировать' : 'Активировать' %>">
                      <i data-lucide="<%= client.isActive !== false ? 'user-x' : 'user-check' %>" class="w-4 h-4"></i>
                    </button>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      
      <!-- Пагинация -->
      <% 
        var totalPagesNum = typeof totalPages !== 'undefined' ? totalPages : 1;
        var currentPage = typeof page !== 'undefined' ? page : 1;
      %>
      <% if (totalPagesNum > 1) { %>
        <div class="px-4 py-3 border-t border-gray-200 flex items-center justify-between">
          <div class="text-sm text-gray-600">
            Страница <%= currentPage %> из <%= totalPagesNum %>
            <span class="text-gray-400 ml-2">(показано <%= clientsList.length %> из <%= typeof totalClients !== 'undefined' ? totalClients : clientsList.length %>)</span>
          </div>
          <div class="flex gap-1">
            <% if (currentPage > 1) { %>
              <a href="?page=<%= currentPage - 1 %>&search=<%= typeof search !== 'undefined' ? search : '' %>&status=<%= typeof status !== 'undefined' ? status : '' %>&clientType=<%= typeof clientType !== 'undefined' ? clientType : '' %>&sort=<%= typeof sort !== 'undefined' ? sort : '' %>" 
                class="px-3 py-1 border rounded hover:bg-gray-50">←</a>
            <% } %>
            <% for (var i = Math.max(1, currentPage - 2); i <= Math.min(totalPagesNum, currentPage + 2); i++) { %>
              <a href="?page=<%= i %>&search=<%= typeof search !== 'undefined' ? search : '' %>&status=<%= typeof status !== 'undefined' ? status : '' %>&clientType=<%= typeof clientType !== 'undefined' ? clientType : '' %>&sort=<%= typeof sort !== 'undefined' ? sort : '' %>" 
                class="px-3 py-1 border rounded <%= i === currentPage ? 'bg-blue-600 text-white border-blue-600' : 'hover:bg-gray-50' %>"><%= i %></a>
            <% } %>
            <% if (currentPage < totalPagesNum) { %>
              <a href="?page=<%= currentPage + 1 %>&search=<%= typeof search !== 'undefined' ? search : '' %>&status=<%= typeof status !== 'undefined' ? status : '' %>&clientType=<%= typeof clientType !== 'undefined' ? clientType : '' %>&sort=<%= typeof sort !== 'undefined' ? sort : '' %>" 
                class="px-3 py-1 border rounded hover:bg-gray-50">→</a>
            <% } %>
          </div>
        </div>
      <% } %>
    <% } else { %>
      <div class="p-12 text-center">
        <i data-lucide="users" class="w-12 h-12 text-gray-300 mx-auto mb-4"></i>
        <p class="text-gray-500 mb-4">Клиенты не найдены</p>
        <a href="/admin/clients/create" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
          <i data-lucide="user-plus" class="w-4 h-4"></i>
          Добавить первого клиента
        </a>
      </div>
    <% } %>
  </div>
</div>

<input type="hidden" id="csrfToken" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

<script>
(function() {
  if (typeof lucide !== 'undefined') lucide.createIcons();
  
  var csrfToken = document.getElementById('csrfToken').value;
  
  // Переключение статуса клиента
  document.querySelectorAll('[data-toggle-status]').forEach(function(btn) {
    btn.addEventListener('click', async function(e) {
      e.preventDefault();
      e.stopPropagation();
      
      var id = this.dataset.toggleStatus;
      var isActive = this.dataset.active === 'true';
      var action = isActive ? 'deactivate' : 'activate';
      
      if (isActive && !confirm('Деактивировать клиента?')) return;
      
      try {
        var res = await fetch('/admin/clients/' + id + '/' + action, {
          method: 'PATCH',
          headers: { 'X-CSRF-Token': csrfToken }
        });
        var data = await res.json();
        if (data.success) location.reload();
        else alert(data.message || 'Ошибка');
      } catch (e) {
        alert('Ошибка сети');
      }
    });
  });
})();
</script>
