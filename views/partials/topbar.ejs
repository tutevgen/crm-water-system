<% 
// Защита от undefined user
const currentUser = typeof user !== 'undefined' ? user : null;
%>

<header class="bg-white shadow-sm border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      
      <!-- Логотип и название -->
      <div class="flex items-center">
        
      </div>

      <!-- Информация о пользователе -->
      <div class="flex items-center gap-4">
        <% if (currentUser) { %>
          <!-- Уведомления -->
          <button class="p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
            </svg>
          </button>

          <!-- Профиль пользователя -->
          <div class="flex items-center gap-3">
            <div class="flex items-center gap-2">
              <% if (currentUser.avatar) { %>
                <img src="<%= currentUser.avatar.startsWith('/') ? currentUser.avatar : '/img/avatars/' + currentUser.avatar %>" 
                     alt="<%= currentUser.name %>" 
                     class="w-10 h-10 rounded-full object-cover border-2 border-gray-200"
                     onerror="this.onerror=null; this.src='/img/default-avatar.png';">
              <% } else { %>
                <div class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center text-sm font-bold uppercase">
                  <%= currentUser.name.substring(0, 2) %>
                </div>
              <% } %>
            </div>

            <!-- Dropdown меню -->
            <div class="relative group">
              <button class="flex items-center gap-2 text-gray-700 hover:text-gray-900">
                <div class="text-left">
                  <div class="text-sm font-medium"><%= currentUser.name %></div>
                  <div class="text-xs text-gray-500">
                    <% 
                    const roleNames = {
                      admin: 'Администратор',
                      manager: 'Менеджер',
                      client: 'Клиент',
                      installer: 'Монтажник'
                    };
                    %>
                    <%= roleNames[currentUser.role] || currentUser.role %>
                  </div>
                </div>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>

              <!-- Выпадающее меню -->
              <div class="hidden group-hover:block absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-200 z-50">
                <a href="/<%= currentUser.role %>/settings" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 rounded-t-lg">
                  <i data-lucide="settings" class="w-4 h-4 inline mr-2"></i>
                  Настройки
                </a>
                <a href="/<%= currentUser.role %>/dashboard" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                  <i data-lucide="layout-dashboard" class="w-4 h-4 inline mr-2"></i>
                  Панель управления
                </a>
                <hr class="my-1">
                <form action="/logout" method="POST" class="m-0">
                  <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                  <button type="submit" class="w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 rounded-b-lg">
                    <i data-lucide="log-out" class="w-4 h-4 inline mr-2"></i>
                    Выход
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% } else { %>
          <!-- Если пользователь не авторизован -->
          <div class="flex items-center gap-2">
            <a href="/login" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900">
              Войти
            </a>
            <a href="/register" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg">
              Регистрация
            </a>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</header>