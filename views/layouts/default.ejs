<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | Nova Filter CRM' : 'Nova Filter CRM' %></title>
  <link rel="icon" href="/img/favicon.ico" type="image/x-icon">
  <link href="/style.css" rel="stylesheet">
  <script src="/js/lucide.min.js"></script>
</head>
<body class="bg-gray-100 min-h-screen">
  
  <% 
    // Защита от undefined
    var currentUser = typeof user !== 'undefined' ? user : null;
    var currentPage = typeof activePage !== 'undefined' ? activePage : '';
    var currentCsrfToken = typeof csrfToken !== 'undefined' ? csrfToken : '';
  %>

  <!-- Sidebar -->
  <aside class="fixed top-0 left-0 w-64 h-screen bg-white border-r border-gray-200 z-30 flex flex-col">
    <!-- Логотип -->
    <div class="p-3 border-b border-gray-200 flex items-center justify-center">
      <img src="/img/logo.png" alt="Nova Filter" class="h-12 w-auto">
    </div>
    
    <!-- Навигация -->
    <nav class="flex-1 p-4 space-y-2 text-sm overflow-y-auto">
      <% 
        var rolePath = '/' + (currentUser ? currentUser.role : 'guest');
        var icons = {
          dashboard: 'home', 
          docs: 'file-text', 
          history: 'clock',
          store: 'shopping-cart', 
          cart: 'shopping-bag',
          calendar: 'calendar-days', 
          clients: 'users',
          orders: 'clipboard-list', 
          products: 'package', 
          proposals: 'file-check',
          requests: 'inbox', 
          tasks: 'check-circle', 
          trips: 'map-pin',
          managers: 'briefcase', 
          technicians: 'wrench', 
          settings: 'settings',
          system: 'cpu',
          categories: 'folder-tree'
        };
        var navLinks = {
          client: [
            { href: 'dashboard', label: 'Главная' },
            { href: 'docs', label: 'Документация' },
            { href: 'history', label: 'История' },
            { href: 'store', label: 'Продукция' },
            { href: 'cart', label: 'Корзина' },
            { href: 'system', label: 'Система' },
            { href: 'settings', label: 'Настройки' }
          ],
          installer: [
            { href: 'dashboard', label: 'Главная' },
            { href: 'calendar', label: 'Календарь' },
            { href: 'requests', label: 'Заявки' },
            { href: 'trips', label: 'Мои выезды' },
            { href: 'settings', label: 'Настройки' }
          ],
          manager: [
            { href: 'dashboard', label: 'Главная' },
            { href: 'calendar', label: 'Календарь' },
            { href: 'clients', label: 'Клиенты' },
            { href: 'orders', label: 'Заказы' },
            { href: 'products', label: 'Продукция' },
            { href: 'proposals', label: 'Ком. предложения' },
            { href: 'requests', label: 'Заявки' },
            { href: 'tasks', label: 'Задачи' },
            { href: 'settings', label: 'Настройки' }
          ],
          admin: [
            { href: 'dashboard', label: 'Главная' },
            { href: 'calendar', label: 'Календарь' },
            { href: 'clients', label: 'Клиенты' },
            { href: 'managers', label: 'Менеджеры' },
            { href: 'technicians', label: 'Монтажники' },
            { href: 'orders', label: 'Заказы' },
            { href: 'products', label: 'Продукция' },
            { href: 'categories', label: 'Категории' },
            { href: 'proposals', label: 'Ком. предложения' },
            { href: 'requests', label: 'Заявки' },
            { href: 'tasks', label: 'Задачи' },
            { href: 'settings', label: 'Настройки' }
          ]
        };
        var links = currentUser && navLinks[currentUser.role] ? navLinks[currentUser.role] : [];
      %>
      
      <% if (links.length > 0) { %>
        <% links.forEach(function(link) { %>
          <% var isActive = currentPage === link.href || currentPage.indexOf(link.href + '/') === 0; %>
          <a href="<%= rolePath + '/' + link.href %>"
             class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition <%= isActive ? 'bg-zinc-900 text-white' : 'hover:bg-gray-100 text-gray-700' %>">
            <i data-lucide="<%= icons[link.href] || 'circle' %>" class="w-5 h-5"></i>
            <span><%= link.label %></span>
          </a>
        <% }); %>
      <% } else { %>
        <div class="text-gray-500 text-xs px-3">Нет доступных разделов</div>
      <% } %>
    </nav>
    
    <!-- Нижняя часть sidebar -->
    <div class="p-4 border-t border-gray-200">
      <div class="text-xs text-gray-400 text-center">
        Nova Filter CRM v1.0
      </div>
    </div>
  </aside>

  <!-- Topbar -->
  <header class="fixed top-0 left-64 right-0 h-16 bg-white border-b border-gray-200 z-20">
    <div class="h-full px-6 flex justify-between items-center">
      
      <!-- Левая часть - заголовок страницы -->
      <div class="flex items-center">
        <h1 class="text-lg font-semibold text-gray-900">
          <%= typeof title !== 'undefined' ? title : 'Панель управления' %>
        </h1>
      </div>

      <!-- Правая часть - пользователь -->
      <div class="flex items-center gap-4">
        <% if (currentUser) { %>
          <!-- Уведомления -->
          <button class="p-2 text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg relative">
            <i data-lucide="bell" class="w-5 h-5"></i>
            <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full"></span>
          </button>

          <!-- Профиль пользователя -->
          <div class="flex items-center gap-3">
            <div class="flex items-center gap-2">
              <% if (currentUser.avatar) { %>
                <img src="<%= currentUser.avatar.indexOf('/') === 0 ? currentUser.avatar : '/img/avatars/' + currentUser.avatar %>" 
                     alt="<%= currentUser.name %>" 
                     class="w-10 h-10 rounded-full object-cover border-2 border-gray-200"
                     onerror="this.onerror=null; this.src='/img/default-avatar.png';">
              <% } else { %>
                <div class="w-10 h-10 bg-zinc-900 text-white rounded-full flex items-center justify-center text-sm font-bold uppercase">
                  <%= currentUser.name.substring(0, 2) %>
                </div>
              <% } %>
            </div>

            <!-- Dropdown меню -->
            <div class="relative" id="userDropdown">
              <button type="button" id="userDropdownBtn" class="flex items-center gap-2 text-gray-700 hover:text-gray-900">
                <div class="text-left">
                  <div class="text-sm font-medium"><%= currentUser.name %></div>
                  <div class="text-xs text-gray-500">
                    <% 
                    var roleNames = {
                      admin: 'Администратор',
                      manager: 'Менеджер',
                      client: 'Клиент',
                      installer: 'Монтажник'
                    };
                    %>
                    <%= roleNames[currentUser.role] || currentUser.role %>
                  </div>
                </div>
                <i data-lucide="chevron-down" class="w-4 h-4 transition-transform" id="dropdownArrow"></i>
              </button>

              <!-- Выпадающее меню -->
              <div id="userDropdownMenu" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-200 z-50">
                <a href="/<%= currentUser.role %>/settings" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 rounded-t-lg">
                  <i data-lucide="settings" class="w-4 h-4"></i>
                  Настройки
                </a>
                <a href="/<%= currentUser.role %>/dashboard" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                  <i data-lucide="layout-dashboard" class="w-4 h-4"></i>
                  Панель управления
                </a>
                <hr class="my-1">
                <form action="/logout" method="POST" class="m-0">
                  <input type="hidden" name="_csrf" value="<%= currentCsrfToken %>">
                  <button type="submit" class="w-full flex items-center gap-2 px-4 py-2 text-sm text-red-600 hover:bg-red-50 rounded-b-lg text-left">
                    <i data-lucide="log-out" class="w-4 h-4"></i>
                    Выход
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% } else { %>
          <!-- Если пользователь не авторизован -->
          <div class="flex items-center gap-2">
            <a href="/login" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900">
              Войти
            </a>
            <a href="/register" class="px-4 py-2 text-sm font-medium text-white bg-zinc-900 hover:bg-zinc-800 rounded-lg">
              Регистрация
            </a>
          </div>
        <% } %>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="ml-64 pt-16 min-h-screen">
    <%- body %>
  </main>

  <script>
    lucide.createIcons();
    
    // Dropdown меню пользователя
    (function() {
      var dropdownBtn = document.getElementById('userDropdownBtn');
      var dropdownMenu = document.getElementById('userDropdownMenu');
      var dropdownArrow = document.getElementById('dropdownArrow');
      var dropdown = document.getElementById('userDropdown');
      
      if (!dropdownBtn || !dropdownMenu) return;
      
      var isOpen = false;
      
      function openMenu() {
        dropdownMenu.classList.remove('hidden');
        if (dropdownArrow) dropdownArrow.classList.add('rotate-180');
        isOpen = true;
      }
      
      function closeMenu() {
        dropdownMenu.classList.add('hidden');
        if (dropdownArrow) dropdownArrow.classList.remove('rotate-180');
        isOpen = false;
      }
      
      // Клик по кнопке
      dropdownBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        if (isOpen) {
          closeMenu();
        } else {
          openMenu();
        }
      });
      
      // Клик вне меню закрывает его
      document.addEventListener('click', function(e) {
        if (isOpen && !dropdown.contains(e.target)) {
          closeMenu();
        }
      });
      
      // Закрытие по Escape
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && isOpen) {
          closeMenu();
        }
      });
    })();
  </script>
</body>
</html>
