<% layout('layouts/auth') %>

<div class="bg-white rounded-xl shadow-xl w-full max-w-md p-8">
  <div class="text-center mb-6">
    <img src="/img/logo.png" alt="Nova Filter" class="h-12 mx-auto mb-4">
    <h1 class="text-2xl font-bold">Новый пароль</h1>
    <p class="text-gray-600 mt-2">Придумайте новый надёжный пароль</p>
  </div>
  
  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <% var successMessages = Array.isArray(success) ? success : [success]; %>
    <% successMessages.forEach(function(msg) { %>
      <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-3 mb-4 text-sm rounded">
        <%= msg %>
      </div>
    <% }); %>
  <% } %>
  
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <% var errorMessages = Array.isArray(error) ? error : [error]; %>
    <% errorMessages.forEach(function(msg) { %>
      <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-3 mb-4 text-sm rounded">
        <%= msg %>
      </div>
    <% }); %>
  <% } %>
  
  <form action="/reset-password" method="POST" class="space-y-4" novalidate>
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Новый пароль</label>
      <input type="password" name="password" required minlength="6"
             class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:border-transparent"
             placeholder="Минимум 6 символов">
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Подтверждение пароля</label>
      <input type="password" name="confirmPassword" required 
             class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:border-transparent"
             placeholder="Повторите пароль">
    </div>
    
    <button type="submit" class="w-full bg-gray-900 text-white py-2.5 rounded-lg hover:bg-gray-800 transition font-medium">
      Сохранить пароль
    </button>
  </form>
  
  <div class="mt-6 text-center text-sm">
    <a href="/login" class="text-gray-500 hover:text-gray-700">← Вернуться к входу</a>
  </div>
</div>
