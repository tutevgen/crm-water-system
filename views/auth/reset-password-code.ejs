<% layout('layouts/auth') %>

<div class="bg-white rounded-xl shadow-xl w-full max-w-md p-8">
  <div class="text-center mb-6">
    <img src="/img/logo.png" alt="Nova Filter" class="h-12 mx-auto mb-4">
    <h1 class="text-2xl font-bold">Введите код</h1>
    <p class="text-gray-600 mt-2">Код отправлен на <strong><%= typeof login !== 'undefined' ? login : '' %></strong></p>
  </div>
  
  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <% var successMessages = Array.isArray(success) ? success : [success]; %>
    <% successMessages.forEach(function(msg) { %>
      <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-3 mb-4 text-sm rounded">
        <%= msg %>
      </div>
    <% }); %>
  <% } %>
  
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <% var errorMessages = Array.isArray(error) ? error : [error]; %>
    <% errorMessages.forEach(function(msg) { %>
      <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-3 mb-4 text-sm rounded">
        <%= msg %>
      </div>
    <% }); %>
  <% } %>
  
  <form action="/reset-password-code" method="POST" class="space-y-4" novalidate>
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Код из письма/SMS</label>
      <input type="text" name="code" required maxlength="6" pattern="[0-9]{6}"
             class="w-full border border-gray-300 rounded-lg px-4 py-3 text-center text-2xl tracking-widest font-mono focus:outline-none focus:ring-2 focus:ring-gray-400 focus:border-transparent"
             placeholder="______"
             autocomplete="one-time-code">
    </div>
    
    <button type="submit" class="w-full bg-gray-900 text-white py-2.5 rounded-lg hover:bg-gray-800 transition font-medium">
      Продолжить
    </button>
  </form>
  
  <div class="mt-6 text-center">
    <p class="text-gray-600 text-sm mb-3">Не получили код?</p>
    <button type="button" id="resendBtn" onclick="resendResetCode()" 
            class="text-gray-900 font-medium hover:underline text-sm">
      Отправить повторно
    </button>
  </div>
  
  <div class="mt-4 text-center">
    <a href="/forgot-password" class="text-gray-500 hover:text-gray-700 text-sm">← Изменить email/телефон</a>
  </div>
</div>

<script>
var csrfToken = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';

function resendResetCode() {
  var btn = document.getElementById('resendBtn');
  btn.disabled = true;
  btn.textContent = 'Отправка...';
  
  fetch('/resend-reset-code', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': csrfToken
    }
  })
  .then(function(res) { return res.json(); })
  .then(function(data) {
    if (data.success) {
      btn.textContent = 'Код отправлен!';
      btn.classList.add('text-green-600');
      setTimeout(function() {
        btn.textContent = 'Отправить повторно';
        btn.classList.remove('text-green-600');
        btn.disabled = false;
      }, 30000);
    } else {
      btn.textContent = data.message || 'Ошибка';
      btn.classList.add('text-red-600');
      setTimeout(function() {
        btn.textContent = 'Отправить повторно';
        btn.classList.remove('text-red-600');
        btn.disabled = false;
      }, 3000);
    }
  })
  .catch(function(err) {
    btn.textContent = 'Ошибка сети';
    btn.disabled = false;
  });
}
</script>
